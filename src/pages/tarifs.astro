    .feedback-inner { flex-wrap: wrap; }
  }

  @media (max-width: 480px) {
    .note-link { font-size: 0.9rem; }
  }
</style>

<script>
  const BASE_PRICES = { wordpress: 2200, astro: 3000 };
  const TECH_LABELS = { wordpress: 'WordPress', astro: 'Astro' };

  const TECH_FEEDBACK = {
    wordpress: {
      title: 'Bon choix pour gérer votre contenu en autonomie',
      detail: "WordPress · Interface d'administration simple, grande communauté, très flexible.",
      tags: ['Autonomie client', 'Contenu facile', 'Évolutif']
    },
    astro: {
      title: 'Bon choix pour la performance et la durabilité',
      detail: 'Astro · PageSpeed 95+, SEO technique optimisé, site rapide pour vos visiteurs.',
      tags: ['Performance ×10', 'SEO renforcé', 'Pérenne']
    }
  };

  const PAGE_NOTES = [
    { min: 1,  max: 1,  msg: 'Une page vitrine bien construite suffit souvent pour un lancement.' },
    { min: 2,  max: 4,  msg: 'Idéal pour séparer accueil, services et contact.' },
    { min: 5,  max: 9,  msg: 'Un site complet : accueil, services, à propos, réalisations, contact.' },
    { min: 10, max: 14, msg: 'Bon niveau de détail pour référencer plusieurs offres ou secteurs.' },
    { min: 15, max: 19, msg: 'Site riche, plusieurs univers ou gammes de services.' },
    { min: 20, max: 20, msg: "Structure complète, proche d'un site institutionnel." }
  ];

  const PAGE_PRICE = 300;

  let state = { tech: 'wordpress', pages: 1, options: [], quizAnswers: {} };
  let quizStep = 1;

  // GOAL CARDS
  document.querySelectorAll('.goal-card').forEach(card => {
    card.addEventListener('click', () => {
      document.querySelectorAll('.goal-card').forEach(c => c.classList.remove('active'));
      card.classList.add('active');
      const goal = card.dataset.goal;
      if (goal === 'help') {
        const quiz = document.getElementById('guided-quiz');
        quiz.style.display = 'block';
        quizStep = 1;
        updateQuizUI();
        setTimeout(() => quiz.scrollIntoView({ behavior: 'smooth', block: 'nearest' }), 50);
      } else {
        document.getElementById('guided-quiz').style.display = 'none';
        setTech(card.dataset.tech);
      }
    });
  });

  // QUIZ BUTTONS
  document.querySelectorAll('.quiz-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const q = parseInt(btn.dataset.q);
      state.quizAnswers[q] = btn.dataset.val;
      btn.parentElement.querySelectorAll('.quiz-btn').forEach(b => b.style.borderColor = '#2a2a2a');
      btn.style.borderColor = 'var(--orange)';
      setTimeout(() => {
        if (q < 3) { quizStep = q + 1; updateQuizUI(); }
        else showQuizResult();
      }, 280);
    });
  });

  function updateQuizUI() {
    document.getElementById('quiz-fill').style.width = ((quizStep - 1) / 3 * 100) + '%';
    document.getElementById('quiz-step').textContent = 'Question ' + quizStep + ' / 3';
    document.querySelectorAll('.quiz-question').forEach(q => q.style.display = 'none');
    const cur = document.getElementById('quiz-q' + quizStep);
    if (cur) cur.style.display = 'block';
    document.getElementById('quiz-result').style.display = 'none';
  }

  function showQuizResult() {
    const a = state.quizAnswers;
    document.getElementById('quiz-fill').style.width = '100%';
    document.getElementById('quiz-step').textContent = 'Résultat';
    document.querySelectorAll('.quiz-question').forEach(q => q.style.display = 'none');

    let tech = 'wordpress';
    let reason = '';
    if (a[1] === 'no' && a[2] === 'yes') {
      tech = 'astro';
      reason = "Vous ne souhaitez pas gérer le contenu vous-même et la performance est prioritaire. Astro est taillé pour ça : ultra-rapide, excellent en SEO, et sans overhead CMS.";
    } else if (a[1] === 'yes' && a[3] === 'yes') {
      tech = 'wordpress';
      reason = "Vous voulez mettre à jour votre contenu régulièrement en autonomie. WordPress est parfait : son interface d'administration est accessible sans formation technique.";
    } else if (a[2] === 'yes' && a[3] === 'no') {
      tech = 'astro';
      reason = "La performance et le SEO sont importants, et votre contenu sera stable. Astro génère des pages statiques ultra-rapides, idéales pour ce profil.";
    } else {
      tech = 'wordpress';
      reason = "Pour votre profil, WordPress offre le meilleur équilibre entre flexibilité, autonomie et évolutivité. C'est la solution la plus polyvalente pour démarrer sereinement.";
    }

    document.getElementById('result-tech-name').textContent = TECH_LABELS[tech];
    document.getElementById('result-reason').textContent = reason;
    document.getElementById('quiz-result').style.display = 'block';

    const applyBtn = document.getElementById('result-apply');
    applyBtn.replaceWith(applyBtn.cloneNode(true));
    document.getElementById('result-apply').addEventListener('click', () => {
      document.getElementById('guided-quiz').style.display = 'none';
      setTech(tech);
    });
  }

  function setTech(tech) {
    state.tech = tech;
    const fb = TECH_FEEDBACK[tech];
    document.getElementById('feedback-title').textContent = fb.title;
    document.getElementById('feedback-detail').textContent = fb.detail;
    document.getElementById('feedback-tags').innerHTML = fb.tags.map(t => '<span class="feedback-tag">+ ' + t + '</span>').join('');

    const maintenanceCard = document.getElementById('maintenance-option');
    if (tech === 'wordpress') {
      maintenanceCard.classList.remove('disabled');
    } else {
      maintenanceCard.classList.add('disabled');
      maintenanceCard.classList.remove('active');
      state.options = state.options.filter(o => o.key !== 'maintenance');
    }
    updatePrice();
  }

  // OPTIONS
  document.querySelectorAll('.option-card').forEach(card => {
    card.addEventListener('click', () => {
      if (card.classList.contains('disabled')) return;
      const opt = card.dataset.option;
      const price = parseInt(card.dataset.price);
      if (opt === 'seo-essentiel' || opt === 'seo-premium') {
        document.querySelectorAll('[data-option="seo-essentiel"], [data-option="seo-premium"]').forEach(c => {
          if (c !== card) {
            c.classList.remove('active');
            state.options = state.options.filter(o => o.key !== c.dataset.option);
          }
        });
      }
      card.classList.toggle('active');
      if (card.classList.contains('active')) {
        if (!state.options.find(o => o.key === opt)) state.options.push({ key: opt, price });
      } else {
        state.options = state.options.filter(o => o.key !== opt);
      }
      updatePrice();
    });
  });

  // SLIDER
  const slider = document.getElementById('pages-slider');
  slider.addEventListener('input', e => {
    state.pages = parseInt(e.target.value);
    document.getElementById('pages-display').innerHTML = state.pages + ' <span>' + (state.pages == 1 ? 'page' : 'pages') + '</span>';
    const match = PAGE_NOTES.find(n => state.pages >= n.min && state.pages <= n.max);
    if (match) document.getElementById('pages-note').textContent = match.msg;
    updatePrice();
  });

  function updatePrice() {
    const base = BASE_PRICES[state.tech];
    const pagesBonus = state.pages > 1 ? (state.pages - 1) * PAGE_PRICE : 0;
    const opts = state.options.reduce((a, o) => a + o.price, 0);
    const total = base + pagesBonus + opts;
    const el = document.getElementById('price-total');
    el.textContent = total.toLocaleString('fr-FR') + ' €';
    el.classList.remove('pulse');
    void el.offsetWidth;
    el.classList.add('pulse');
    let detail = '<strong>Site vitrine — ' + TECH_LABELS[state.tech] + '</strong><br>';
    detail += state.pages + ' page' + (state.pages > 1 ? 's' : '');
    if (state.options.length > 0) detail += ' · ' + state.options.length + ' option' + (state.options.length > 1 ? 's' : '') + ' ajoutée' + (state.options.length > 1 ? 's' : '');
    document.getElementById('price-detail').innerHTML = detail;
  }

  setTech('wordpress');
  updatePrice();
</script>