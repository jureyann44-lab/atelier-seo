---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const title = "Tarifs Site Web Le Mans | Simulateur de projet | Habeprod";
const description = "Estimez le prix de votre site web en temps réel. WordPress à partir de 2200€, Astro 3000€. Configurateur transparent avec options SEO, maintenance, identité visuelle. Agence web Le Mans.";
const canonical = "https://www.habeprod-agence.fr/tarifs";
const ogImage = "https://www.habeprod-agence.fr/og-tarifs.jpg";

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "itemListElement": [
    {
      "@type": "Service",
      "position": 1,
      "name": "Site WordPress",
      "description": "Création de site vitrine WordPress avec autonomie de gestion",
      "provider": {
        "@type": "Organization",
        "name": "Habeprod",
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "Le Mans",
          "addressCountry": "FR"
        }
      },
      "offers": {
        "@type": "Offer",
        "price": "2200",
        "priceCurrency": "EUR"
      }
    },
    {
      "@type": "Service",
      "position": 2,
      "name": "Site Astro",
      "description": "Site web ultra-performant avec Astro, PageSpeed 95+",
      "provider": {
        "@type": "Organization",
        "name": "Habeprod"
      },
      "offers": {
        "@type": "Offer",
        "price": "3000",
        "priceCurrency": "EUR"
      }
    },
    {
      "@type": "Service",
      "position": 3,
      "name": "SEO Local Premium",
      "description": "Référencement local Le Mans avec audit complet",
      "provider": {
        "@type": "Organization",
        "name": "Habeprod"
      },
      "offers": {
        "@type": "Offer",
        "price": "1200",
        "priceCurrency": "EUR"
      }
    }
  ]
};
---

<Layout 
  title={title} 
  description={description}
  canonical={canonical}
  ogImage={ogImage}
  ogType="website"
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />

  <Nav />
  
  <main class="tarifs-page">
    <section class="tarifs-hero">
      <div class="container">
        <div class="hero-content">
          <span class="hero-label">Simulateur de projet web</span>
          <h1>Explorez votre futur site<br><span class="highlight">et comprenez ce qui compte</span></h1>
          <p class="hero-subtitle">
            Répondez à quelques questions simples pour découvrir la solution adaptée à votre besoin — et voir ce qui influence réellement le coût.
          </p>
        </div>
      </div>
    </section>

    <section class="configurateur">
      <div class="container">

        <div class="config-section">
          <div class="section-header">
            <span class="section-num">01</span>
            <h2 class="section-title">Quel est votre objectif principal ?</h2>
          </div>

          <div class="cards cards-2" id="goal-cards">
            <div class="goal-card active" data-goal="autonomy" data-tech="wordpress">
              <div class="goal-icon">✏️</div>
              <h3 class="goal-title">Je veux modifier mon site facilement moi-même</h3>
              <p class="goal-desc">Mettre à jour les textes, ajouter des photos, publier des articles — sans dépendre d'un développeur.</p>
              <span class="goal-reco">→ Solution recommandée : <strong>WordPress</strong></span>
            </div>
            <div class="goal-card" data-goal="performance" data-tech="astro">
              <div class="goal-icon">⚡</div>
              <h3 class="goal-title">Je veux un site ultra-rapide et durable dans le temps</h3>
              <p class="goal-desc">Performances maximales, excellente visibilité Google, site fiable qui ne vieillit pas mal.</p>
              <span class="goal-reco">→ Solution recommandée : <strong>Astro</strong></span>
            </div>
            <div class="goal-card" data-goal="simple" data-tech="wordpress">
              <div class="goal-icon">🎯</div>
              <h3 class="goal-title">Je veux une solution simple et évolutive</h3>
              <p class="goal-desc">Un bon site professionnel, qui peut grandir avec mon activité, sans me prendre la tête.</p>
              <span class="goal-reco">→ Solution recommandée : <strong>WordPress</strong></span>
            </div>
            <div class="goal-card goal-card--help" data-goal="help" data-tech="">
              <div class="goal-icon">🤔</div>
              <h3 class="goal-title">Je ne sais pas encore — aidez-moi à choisir</h3>
              <p class="goal-desc">3 questions rapides pour identifier la solution qui correspond vraiment à votre situation.</p>
              <span class="goal-reco goal-reco--neutral">→ Parcours guidé</span>
            </div>
          </div>

          <div class="guided-quiz" id="guided-quiz" style="display:none;">
            <div class="quiz-progress">
              <div class="quiz-bar"><div class="quiz-fill" id="quiz-fill"></div></div>
              <span class="quiz-step" id="quiz-step">Question 1 / 3</span>
            </div>
            <div class="quiz-question" id="quiz-q1">
              <p class="quiz-label">Souhaitez-vous pouvoir modifier vous-même le contenu de votre site (textes, photos…) ?</p>
              <div class="quiz-answers">
                <button class="quiz-btn" data-q="1" data-val="yes">Oui, c'est important pour moi</button>
                <button class="quiz-btn" data-q="1" data-val="no">Non, je délègue tout à l'agence</button>
              </div>
            </div>
            <div class="quiz-question" id="quiz-q2" style="display:none;">
              <p class="quiz-label">La vitesse de chargement et le référencement Google sont-ils prioritaires pour vous ?</p>
              <div class="quiz-answers">
                <button class="quiz-btn" data-q="2" data-val="yes">Oui, c'est crucial pour mon activité</button>
                <button class="quiz-btn" data-q="2" data-val="no">C'est secondaire pour l'instant</button>
              </div>
            </div>
            <div class="quiz-question" id="quiz-q3" style="display:none;">
              <p class="quiz-label">Prévoyez-vous d'ajouter régulièrement du contenu (blog, actualités, nouveaux services…) ?</p>
              <div class="quiz-answers">
                <button class="quiz-btn" data-q="3" data-val="yes">Oui, régulièrement</button>
                <button class="quiz-btn" data-q="3" data-val="no">Non, le site sera relativement stable</button>
              </div>
            </div>
            <div class="quiz-result" id="quiz-result" style="display:none;">
              <div class="result-reco">
                <span class="result-label">Notre recommandation pour vous</span>
                <h3 class="result-tech" id="result-tech-name"></h3>
                <p class="result-reason" id="result-reason"></p>
                <button class="result-apply" id="result-apply">Appliquer cette recommandation →</button>
              </div>
            </div>
          </div>

          <div class="tech-feedback" id="tech-feedback">
            <div class="feedback-inner">
              <span class="feedback-check">✓</span>
              <div class="feedback-text">
                <strong id="feedback-title">Bon choix pour gérer votre contenu en autonomie</strong>
                <span id="feedback-detail">WordPress · Interface d'administration simple, grande communauté, très flexible.</span>
              </div>
              <div class="feedback-tags" id="feedback-tags"></div>
            </div>
          </div>
        </div>

        <div class="config-section">
          <div class="section-header">
            <span class="section-num">02</span>
            <h2 class="section-title">Nombre de pages</h2>
          </div>
          <div class="slider-wrap">
            <div class="slider-header">
              <div class="slider-value" id="pages-display">1 <span>page</span></div>
              <span class="slider-hint">Glissez pour ajuster</span>
            </div>
            <input type="range" id="pages-slider" min="1" max="20" value="1">
            <div class="slider-ticks">
              <span>1</span>
              <span>5</span>
              <span>10</span>
              <span>15</span>
              <span>20+</span>
            </div>
            <p class="slider-note" id="pages-note">Une page vitrine bien construite suffit souvent pour un lancement.</p>
          </div>
        </div>

        <div class="config-section">
          <div class="section-header">
            <span class="section-num">03</span>
            <h2 class="section-title">Options & services</h2>
          </div>

          <div class="seo-intro">
            <h3 class="seo-intro-title">Optimisation SEO & visibilité</h3>
            <p class="seo-intro-text">Le site inclut déjà une optimisation SEO de base lors de sa création (structure, performances et bonnes pratiques techniques). Les options ci-dessous correspondent à un accompagnement SEO renforcé, destiné à améliorer votre visibilité et vos résultats selon vos objectifs de développement.</p>
          </div>

          <div class="options-grid">
            <div class="option-card" data-option="seo-essentiel" data-price="800">
              <div class="option-checkbox"><span class="checkmark">✓</span></div>
              <div class="option-info">
                <h3 class="option-name">Renforcement SEO Local</h3>
                <span class="option-price">+ 800 €</span>
                <span class="option-benefit">Renforce l'optimisation déjà intégrée pour améliorer votre visibilité sur les recherches locales.</span>
                <ul class="option-checklist">
                  <li>Optimisation sémantique locale</li>
                  <li>Ajustement des balises stratégiques</li>
                  <li>Structuration des contenus clés</li>
                  <li>Optimisation Google Business &amp; recherches locales</li>
                </ul>
              </div>
            </div>
            <div class="option-card" data-option="seo-premium" data-price="1200">
              <div class="option-checkbox"><span class="checkmark">✓</span></div>
              <div class="option-info">
                <h3 class="option-name">SEO Local Avancé</h3>
                <span class="option-price">+ 1 200 €</span>
                <span class="option-benefit">Accompagnement approfondi pour dépasser vos concurrents locaux sur les recherches stratégiques.</span>
                <ul class="option-checklist">
                  <li>Audit SEO complet</li>
                  <li>Recherche &amp; stratégie de mots-clés</li>
                  <li>Optimisation avancée des pages</li>
                  <li>Maillage interne stratégique</li>
                  <li>Optimisation concurrentielle locale</li>
                </ul>
              </div>
            </div>

          <div class="seo-reassurance">
            💡 Ces options ne remplacent pas le SEO inclus dans le site : elles permettent d'aller plus loin selon vos objectifs de croissance.
          </div>
            <div class="option-card" id="maintenance-option" data-option="maintenance" data-price="1200">
              <div class="option-checkbox"><span class="checkmark">✓</span></div>
              <div class="option-info">
                <h3 class="option-name">Maintenance annuelle</h3>
                <span class="option-price">+ 1 200 € / an</span>
                <span class="option-benefit">Votre site reste sécurisé et à jour sans que vous ayez à y penser.</span>
                <span class="option-note">WordPress uniquement · Sauvegardes + mises à jour + support</span>
              </div>
            </div>
            <div class="option-card" data-option="logo" data-price="600">
              <div class="option-checkbox"><span class="checkmark">✓</span></div>
              <div class="option-info">
                <h3 class="option-name">Création de logo</h3>
                <span class="option-price">+ 600 €</span>
                <span class="option-benefit">Une identité visuelle propre, cohérente sur tous vos supports.</span>
                <span class="option-note">2-3 propositions · Fichiers sources inclus</span>
              </div>
            </div>
            <div class="option-card" data-option="identite" data-price="1500">
              <div class="option-checkbox"><span class="checkmark">✓</span></div>
              <div class="option-info">
                <h3 class="option-name">Identité visuelle complète</h3>
                <span class="option-price">+ 1 500 €</span>
                <span class="option-benefit">Vous êtes reconnaissable partout : site, réseaux, print.</span>
                <span class="option-note">Logo + charte graphique + déclinaisons</span>
              </div>
            </div>
            <div class="option-card" data-option="figma" data-price="600">
              <div class="option-checkbox"><span class="checkmark">✓</span></div>
              <div class="option-info">
                <h3 class="option-name">Formation Figma</h3>
                <span class="option-price">+ 600 €</span>
                <span class="option-benefit">Vous créez vos visuels en autonomie sans dépendre d'un designer.</span>
                <span class="option-note">Session personnalisée · Prise en main autonome</span>
              </div>
            </div>
            <div class="option-card" data-option="redaction" data-price="700">
              <div class="option-checkbox"><span class="checkmark">✓</span></div>
              <div class="option-info">
                <h3 class="option-name">Rédaction One Page</h3>
                <span class="option-price">+ 700 €</span>
                <span class="option-benefit">Votre message est clair, convaincant, et optimisé pour Google.</span>
                <span class="option-note">Contenu SEO optimisé et structuré</span>
              </div>
            </div>
          </div>
        </div>

        <div class="price-panel">
          <div class="price-content">
            <div class="price-left">
              <span class="price-label">Estimation de votre projet</span>
              <div class="price-total" id="price-total">2 200 €</div>
              <div class="price-detail" id="price-detail">
                <strong>Site vitrine — WordPress</strong><br>
                1 page (one page) · Tarifs indicatifs
              </div>
            </div>
            <a href="/#contact" class="price-cta">
              <span>Demander un devis</span>
            </a>
          </div>
        </div>

        <div class="note-ecommerce">
          <p><strong>Vous avez besoin d'un site e-commerce ?</strong></p>
          <p>Nos solutions e-commerce (WooCommerce, Shopify, Astro + Shopify) sont disponibles sur devis personnalisé.</p>
          <a href="/#contact" class="note-link">Demander un devis e-commerce →</a>
        </div>

        <div class="tarifs-footer">
          <a href="/" class="back-to-home">
            <span class="back-arrow">←</span>
            <span class="back-text">Retour à l'accueil</span>
          </a>
        </div>

      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  :root {
    --orange: #ea6432;
    --black: #000000;
    --white: #ffffff;
    --gray: #9ca3af;
    --dark-card: #1a1a1a;
  }

  .tarifs-page {
    background: var(--black);
    padding-top: 100px;
  }

  .container {
    max-width: var(--layout-width);
    margin: 0 auto;
    padding-left: var(--gutter);
    padding-right: var(--gutter);
  }

  .tarifs-hero {
    padding: 80px 0 0 !important;
    padding-bottom: 0 !important;
    text-align: left;
  }

  .hero-content { max-width: 800px; }

  .hero-label {
    display: block;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--gray);
    margin-bottom: 16px;
  }

  .tarifs-hero h1 {
    font-size: 32px;
    font-weight: 600;
    line-height: 1.15;
    margin-bottom: 20px;
    color: var(--white);
  }

  .highlight { color: var(--orange); }

  .hero-subtitle {
    font-size: 1.1rem;
    line-height: 1.6;
    color: var(--gray);
    max-width: 600px;
  }

  .configurateur { padding: 40px 0 120px; }
  .config-section { margin-bottom: 64px; }

  .section-header {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 32px;
  }

  .section-num {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--orange);
    min-width: 32px;
  }

  .section-title {
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--white);
  }

  .cards { display: grid; gap: 16px; }
  .cards-2 { grid-template-columns: repeat(2, 1fr); }

  @media (max-width: 600px) {
    .cards-2 { grid-template-columns: 1fr; }
  }

  .goal-card {
    background: var(--dark-card);
    border: 2px solid #2a2a2a;
    border-radius: 12px;
    padding: 24px;
    cursor: pointer;
    transition: all 0.3s ease;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .goal-card:hover {
    border-color: var(--orange);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(234, 100, 50, 0.2);
  }

  .goal-card.active {
    border-color: var(--orange);
    background: rgba(234, 100, 50, 0.08);
  }

  .goal-card--help { border-style: dashed; }

  .goal-icon { font-size: 1.5rem; margin-bottom: 4px; }

  .goal-title {
    font-size: 1rem;
    font-weight: 600;
    color: var(--white);
    line-height: 1.3;
  }

  .goal-desc {
    font-size: 0.875rem;
    color: var(--gray);
    line-height: 1.5;
    flex: 1;
  }

  .goal-reco {
    font-size: 0.8rem;
    color: var(--orange);
    font-weight: 600;
    margin-top: 4px;
  }

  .goal-reco--neutral { color: var(--gray); }

  /* GUIDED QUIZ */
  .guided-quiz {
    margin-top: 24px;
    background: var(--dark-card);
    border: 2px solid #2a2a2a;
    border-radius: 12px;
    padding: 32px;
    animation: fadeIn 0.3s ease;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .quiz-progress {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 28px;
  }

  .quiz-bar {
    flex: 1;
    height: 4px;
    background: #2a2a2a;
    border-radius: 2px;
    overflow: hidden;
  }

  .quiz-fill {
    height: 100%;
    background: var(--orange);
    border-radius: 2px;
    transition: width 0.4s ease;
    width: 0%;
  }

  .quiz-step {
    font-size: 0.8rem;
    color: var(--gray);
    white-space: nowrap;
  }

  .quiz-label {
    font-size: 1.05rem;
    color: var(--white);
    font-weight: 500;
    margin-bottom: 20px;
    line-height: 1.5;
  }

  .quiz-answers {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .quiz-btn {
    background: #111;
    border: 2px solid #2a2a2a;
    border-radius: 8px;
    padding: 14px 20px;
    color: var(--white);
    font-size: 0.95rem;
    cursor: pointer;
    text-align: left;
    transition: all 0.2s ease;
    font-family: inherit;
  }

  .quiz-btn:hover {
    border-color: var(--orange);
    background: rgba(234, 100, 50, 0.08);
  }

  .quiz-result { animation: fadeIn 0.3s ease; }

  .result-reco {
    background: rgba(234, 100, 50, 0.08);
    border: 2px solid var(--orange);
    border-radius: 10px;
    padding: 24px;
  }

  .result-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--gray);
    display: block;
    margin-bottom: 8px;
  }

  .result-tech {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--orange);
    margin-bottom: 8px;
  }

  .result-reason {
    color: var(--gray);
    font-size: 0.95rem;
    line-height: 1.6;
    margin-bottom: 20px;
  }

  .result-apply {
    background: var(--orange);
    color: var(--white);
    border: none;
    border-radius: 999px;
    padding: 12px 28px;
    font-size: 0.95rem;
    font-weight: 600;
    cursor: pointer;
    font-family: inherit;
    transition: all 0.2s ease;
  }

  .result-apply:hover {
    background: #d4581f;
    transform: translateY(-1px);
  }

  /* TECH FEEDBACK */
  .tech-feedback {
    margin-top: 16px;
    animation: fadeIn 0.4s ease;
  }

  .feedback-inner {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    background: rgba(234, 100, 50, 0.06);
    border: 1px solid rgba(234, 100, 50, 0.3);
    border-radius: 10px;
    padding: 16px 20px;
  }

  .feedback-check {
    width: 28px;
    height: 28px;
    background: var(--orange);
    color: var(--black);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 14px;
    font-weight: 700;
    flex-shrink: 0;
  }

  .feedback-text { flex: 1; }

  .feedback-text strong {
    display: block;
    color: var(--white);
    font-size: 0.95rem;
    margin-bottom: 2px;
  }

  .feedback-text span {
    color: var(--gray);
    font-size: 0.875rem;
  }

  .feedback-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    align-items: center;
  }

  .feedback-tag {
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--orange);
    background: rgba(234, 100, 50, 0.1);
    padding: 3px 10px;
    border-radius: 999px;
    white-space: nowrap;
  }

  /* SLIDER */
  .slider-wrap {
    background: var(--dark-card);
    border: 2px solid #2a2a2a;
    border-radius: 12px;
    padding: 32px;
    transition: border-color 0.3s ease;
  }

  .slider-wrap:hover { border-color: var(--orange); }

  .slider-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 24px;
  }

  .slider-value {
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--white);
    line-height: 1;
  }

  .slider-value span {
    font-size: 1rem;
    font-weight: 400;
    color: var(--gray);
  }

  .slider-hint {
    font-size: 0.85rem;
    color: var(--orange);
  }

  input[type="range"] {
    width: 100%;
    height: 6px;
    background: #2a2a2a;
    border-radius: 3px;
    outline: none;
    cursor: pointer;
    -webkit-appearance: none;
  }

  input[type="range"]::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 24px;
    height: 24px;
    background: var(--orange);
    border-radius: 50%;
    cursor: pointer;
    box-shadow: 0 2px 8px rgba(234, 100, 50, 0.4);
    transition: transform 0.2s;
  }

  input[type="range"]::-webkit-slider-thumb:hover { transform: scale(1.2); }

  input[type="range"]::-moz-range-thumb {
    width: 24px;
    height: 24px;
    background: var(--orange);
    border-radius: 50%;
    cursor: pointer;
    border: none;
  }

  .slider-ticks {
    position: relative;
    margin-top: 12px;
    height: 20px;
  }

  .slider-ticks span {
    position: absolute;
    font-size: 0.75rem;
    color: var(--gray);
    transform: translateX(-50%);
  }

  .slider-ticks span:nth-child(1) { left: 0%; transform: translateX(0); }
  .slider-ticks span:nth-child(2) { left: 21.05%; }
