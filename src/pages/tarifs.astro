  .option-card.disabled:hover { border-color: #2a2a2a; transform: none; }

  .option-card.disabled .option-name,
  .option-card.disabled .option-price,
  .option-card.disabled .option-benefit,
  .option-card.disabled .option-note { opacity: 0.4; }

  .option-checkbox {
    width: 24px;
