---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
---

<Layout
  title={`${post.data.title} - Habeprod`}
  description={post.data.description}
>
  <Nav />

  <article class="blog-article">
    <div class="container">
      <div class="article-header">
        <div class="article-meta">
          <span class="article-date">{post.data.date}</span>
          <span class="article-author">Par {post.data.author}</span>
        </div>
        <h1>{post.data.title}</h1>
        <p class="article-description">{post.data.description}</p>
      </div>

      <div class="article-content">
        <Content />
      </div>

      <div class="article-footer">
        <a href="/blog" class="back-to-blog">
          <span class="back-arrow">←</span>
          <span class="back-text">Retour aux articles</span>
        </a>
      </div>
    </div>
  </article>

  <Footer />
</Layout>

<style>
  .blog-article {
    background: #020308;
    min-height: 80vh;
    padding: 10rem 0 4rem;
  }

  .container {
    max-width: var(--layout-width);
    margin: 0 auto;
    width: 100%;
    padding: 0 var(--gutter);
  }

  .article-header {
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.15);
  }

  .article-meta {
    display: flex;
    gap: 2rem;
    margin-bottom: 1.5rem;
    font-size: 0.9rem;
    color: #9ca3af;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .article-header h1 {
    font-size: 2.5rem;
    line-height: 1.2;
    margin-bottom: 1rem;
    color: #ffffff;
  }

  .article-description {
    font-size: 1.2rem;
    color: #d1d5db;
    line-height: 1.6;
  }

  .article-content {
    font-size: 1.1rem;
    line-height: 1.8;
    color: #e5e7eb;
  }

  .article-content :global(h2) {
    font-size: 1.8rem;
    margin: 2.5rem 0 1rem;
    color: #ffffff;
  }

  .article-content :global(h3) {
    font-size: 1.4rem;
    margin: 2rem 0 1rem;
    color: #ffffff;
  }

  .article-content :global(p) {
    margin-bottom: 1.5rem;
  }

  .article-content :global(ul),
  .article-content :global(ol) {
    margin: 1.5rem 0;
    padding-left: 2rem;
  }

  .article-content :global(li) {
    margin-bottom: 0.5rem;
  }

  .article-content :global(strong) {
    color: #ffffff;
    font-weight: 600;
  }

  .article-content :global(img) {
    width: 100%;
    height: auto;
    border-radius: 8px;
    margin: 2.5rem 0 0.5rem;
    display: block;
  }

  .article-content :global(img + em) {
    display: block;
    text-align: center;
    font-size: 0.9rem;
    color: #9ca3af;
    font-style: italic;
    margin-top: 0.5rem;
    margin-bottom: 2.5rem;
  }

  .article-content :global(a) {
    color: #ea6432;
    text-decoration: none;
  }

  .article-content :global(a:hover) {
    text-decoration: underline;
  }

  .article-footer {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.15);
  }

  .back-to-blog {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: #ffffff;
    text-decoration: none;
    font-weight: 500;
    transition:
      gap 0.3s ease,
      color 0.3s ease;
  }

  .back-to-blog:hover {
    gap: 0.75rem;
    color: #9ca3af;
  }

  .back-arrow {
    transition: transform 0.3s ease;
  }

  .back-to-blog:hover .back-arrow {
    transform: translateX(-3px);
  }

  /* 📱 MOBILE LANDSCAPE - Padding réduit */
  @media (min-width: 667px) and (max-width: 960px) and (orientation: landscape) and (max-height: 450px) {
    .blog-article {
      padding: 6rem 0 3rem;
    }

    .article-header h1 {
      font-size: 1.75rem;
    }

    .article-description {
      font-size: 1rem;
    }

    .article-content {
      font-size: 0.95rem;
    }

    .article-content :global(h2) {
      font-size: 1.4rem;
    }

    .article-content :global(h3) {
      font-size: 1.2rem;
    }
  }

  /* 📱 iPad Mini PORTRAIT - Container 90% */
  @media (min-width: 768px) and (max-width: 820px) and (orientation: portrait) {
    .container {
      max-width: 90% !important;
      margin: 0 auto !important;
    }
  }

  /* 🔥 MOBILE (tactile OU petit écran) */
  @media (max-width: 900px), (max-width: 1023px) and (pointer: coarse) {
    .blog-article {
      padding: 8rem 0 4rem;
    }

    .article-header h1 {
      font-size: 1.8rem;
    }

    .article-content {
      font-size: 1rem;
    }

    .back-to-blog {
      transition: none;
    }

    .back-to-blog:hover {
      gap: 0.5rem;
      color: #ffffff;
    }

    .back-to-blog:hover .back-arrow {
      transform: none;
    }
  }
</style>
