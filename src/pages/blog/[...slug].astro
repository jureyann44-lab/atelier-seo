---
export const prerender = true;
import { toHTML } from "@portabletext/to-html";
import Layout from "../../layouts/Layout.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";
import { getAllPosts, getPostBySlug } from "../../sanity/queries";
import { urlFor } from "../../sanity/imageUrl";

export async function getStaticPaths() {
  const posts = await getAllPosts();
  return posts.map((post) => ({
    params: { slug: post.slug },
  }));
}

const { slug } = Astro.params;
const post = await getPostBySlug(slug as string);

if (!post) {
  return Astro.redirect("/404");
}

const canonicalUrl = `https://atelier-seo.fr/blog/${post.slug}/`;
const ogImage = post.image
  ? urlFor(post.image).width(1200).height(630).url()
  : "https://atelier-seo.fr/atelier-seo-social.png";

const bodyHtml = post.body ? toHTML(post.body) : "";

function formatDate(dateString: string): string {
  const date = new Date(dateString);
  const day = date.getDate();
  const months = [
    "janvier", "février", "mars", "avril", "mai", "juin",
    "juillet", "août", "septembre", "octobre", "novembre", "décembre",
  ];
  return `${day} ${months[date.getMonth()]} ${date.getFullYear()}`;
}
---

<Layout
  title={`${post.title} | L'Atelier SEO`}
  description={post.description}
  canonical={canonicalUrl}
  ogImage={ogImage}
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": post.title,
    "description": post.description,
    "datePublished": post.date,
    "dateModified": post.date,
    "author": {
      "@type": "Person",
      "@id": "https://atelier-seo.fr/#person",
      "name": "Yann",
      "url": "https://atelier-seo.fr"
    },
    "publisher": {
      "@type": "Organization",
      "name": "L'Atelier SEO",
      "logo": {
        "@type": "ImageObject",
        "url": "https://atelier-seo.fr/logo-atelier-seo.png"
      }
    },
    "url": canonicalUrl,
    ...(post.image ? { "image": ogImage } : {})
  })} />

  <Nav />

  <article class="blog-article">
    <div class="container">
      <div class="article-header">
        <div class="article-meta">
          <span class="article-date">{formatDate(post.date)}</span>
          {post.tags && post.tags.length > 0 && (
            <div class="article-tags">
              {post.tags.map((tag: string) => (
                <span class="article-tag">{tag}</span>
              ))}
            </div>
          )}
        </div>
        <h1>{post.title}</h1>
        <p class="article-description">{post.description}</p>
      </div>

      <div class="article-content" set:html={bodyHtml} />

      <div class="article-footer">
        <a href="/blog" class="back-to-blog">
          <span class="back-arrow">←</span>
          <span class="back-text">Retour aux articles</span>
        </a>
      </div>
    </div>
  </article>

  <Footer />
</Layout>

<style>
  .blog-article {
    background: #020308;
    min-height: 80vh;
    padding: 10rem 0 4rem;
  }

  .container {
    max-width: var(--layout-width);
    margin: 0 auto;
    width: 100%;
    padding: 0 var(--gutter);
  }

  .article-header {
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.15);
  }

  .article-meta {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }

  .article-date {
    font-size: 0.9rem;
    color: #9ca3af;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .article-tags {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .article-tag {
    font-size: 0.75rem;
    color: #9ca3af;
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 4px;
    padding: 0.2rem 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .article-header h1 {
    font-size: 2.5rem;
    line-height: 1.2;
    margin-bottom: 1rem;
    color: #ffffff;
  }

  .article-description {
    font-size: 1.2rem;
    color: #d1d5db;
    line-height: 1.6;
  }

  .article-content {
    font-size: 1.1rem;
    line-height: 1.8;
    color: #e5e7eb;
  }

  .article-content :global(h2) {
    font-size: 1.8rem;
    margin: 2.5rem 0 1rem;
    color: #ffffff;
  }

  .article-content :global(h3) {
    font-size: 1.4rem;
    margin: 2rem 0 1rem;
    color: #ffffff;
  }

  .article-content :global(p) {
    margin-bottom: 1.5rem;
  }

  .article-content :global(ul),
  .article-content :global(ol) {
    margin: 1.5rem 0;
    padding-left: 2rem;
  }

  .article-content :global(li) {
    margin-bottom: 0.5rem;
  }

  .article-content :global(strong) {
    color: #ffffff;
    font-weight: 600;
  }

  .article-content :global(img) {
    width: 100%;
    height: auto;
    border-radius: 8px;
    margin: 2.5rem 0 0.5rem;
    display: block;
  }

  .article-content :global(img + em) {
    display: block;
    text-align: center;
    font-size: 0.9rem;
    color: #9ca3af;
    font-style: italic;
    margin-top: 0.5rem;
    margin-bottom: 2.5rem;
  }

  .article-content :global(a) {
    color: #ea6432;
    text-decoration: none;
  }

  .article-content :global(a:hover) {
    text-decoration: underline;
  }

  .article-content :global(a[href^="mailto"]) {
    display: inline;
    color: #ea6432;
    font-weight: 500;
  }

  .article-content :global(a[href^="tel"]) {
    display: block;
    color: #ea6432;
    text-decoration: none;
    font-weight: 500;
    margin-top: 0.25rem;
  }

  .article-content :global(a[href^="tel"]:hover) {
    text-decoration: underline;
  }

  .article-footer {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.15);
  }

  .back-to-blog {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: #ffffff;
    text-decoration: none;
    font-weight: 500;
    transition: gap 0.3s ease, color 0.3s ease;
  }

  .back-to-blog:hover {
    gap: 0.75rem;
    color: #9ca3af;
  }

  .back-arrow {
    transition: transform 0.3s ease;
  }

  .back-to-blog:hover .back-arrow {
    transform: translateX(-3px);
  }

  @media (min-width: 667px) and (max-width: 960px) and (orientation: landscape) and (max-height: 450px) {
    .blog-article { padding: 6rem 0 3rem; }
    .article-header h1 { font-size: 1.75rem; }
    .article-description { font-size: 1rem; }
    .article-content { font-size: 0.95rem; }
    .article-content :global(h2) { font-size: 1.4rem; }
    .article-content :global(h3) { font-size: 1.2rem; }
  }

  @media (min-width: 768px) and (max-width: 820px) and (orientation: portrait) {
    .container { max-width: 90% !important; margin: 0 auto !important; }
  }

  @media (max-width: 900px), (max-width: 1023px) and (pointer: coarse) {
    .blog-article { padding: 8rem 0 4rem; }
    .article-header h1 { font-size: 1.8rem; }
    .article-content { font-size: 1rem; }
    .back-to-blog { transition: none; }
    .back-to-blog:hover { gap: 0.5rem; color: #ffffff; }
    .back-to-blog:hover .back-arrow { transform: none; }
  }
</style>
