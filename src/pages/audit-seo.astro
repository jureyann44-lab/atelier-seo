<script is:inline>
  var form = document.getElementById('audit-form');
  var urlInput = document.getElementById('url-input');
  var analyzeBtn = document.getElementById('analyze-btn');
  var btnText = analyzeBtn.querySelector('.btn-text');
  var btnLoader = analyzeBtn.querySelector('.btn-loader');
  var resultsDiv = document.getElementById('results');
  var errorDiv = document.getElementById('error');

  form.addEventListener('submit', async function(e) {
    e.preventDefault();

    var url = urlInput.value.trim();
    if (!url) return;

    analyzeBtn.disabled = true;
    btnText.style.display = 'none';
    btnLoader.style.display = 'flex';
    resultsDiv.style.display = 'none';
    errorDiv.style.display = 'none';

    try {
      var response = await fetch('/api/audit.json', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ url: url }),
        signal: AbortSignal.timeout(90000)
      });

      var data = await response.json();

      if (!response.ok || data.error) {
        throw new Error(data.error || "Impossible d'analyser cette URL");
      }

      displayResults(data);
      resultsDiv.style.display = 'block';
      document.getElementById('inline-cta').style.display = 'block';
      document.getElementById('help-block').style.display = 'block';

    } catch (error) {
      console.error('Erreur:', error);
      var msg = error.message;
      if (!msg || msg.includes('fetch') || msg.includes('network') || msg.includes('Failed') || msg.includes('analyser') || msg.includes('Impossible') || msg.includes('timed out') || msg.includes('timeout') || msg.includes('500') || msg.includes('API Google')) {
        msg = "⚠️ Ce site bloque les outils d'analyse automatique (bots, Lighthouse).<br>L'analyse de performance n'est pas possible.";
      }
      document.getElementById('error-message').innerHTML = msg;
      errorDiv.style.display = 'block';
    } finally {
      analyzeBtn.disabled = false;
      btnText.style.display = 'inline';
      btnLoader.style.display = 'none';
    }
  });

  function getSeverityIcon(score) {
    if (score >= 0.9) return '✅';
    if (score >= 0.5) return '⚠️';
    return '❌';
  }

  function getSpeedGrade(score) {
    if (score >= 90) return 'A';
    if (score >= 70) return 'B';
    if (score >= 50) return 'C';
    if (score >= 30) return 'D';
    return 'F';
  }

  function displayResults(data) {
    var lighthouse = data.lighthouseResult;
    var categories = lighthouse.categories;
    var audits = lighthouse.audits;

    var perfScore = Math.round(categories.performance.score * 100);
    var loadingExp = data.loadingExperience || null;
    updateScore(perfScore, loadingExp);
    displayDiagnostic(perfScore);

    // Note vitesse
    var speedGrade = getSpeedGrade(perfScore);
    var speedEl = document.getElementById('speed-grade-letter');
    speedEl.textContent = speedGrade;
    speedEl.className = 'grade-letter ' + speedGrade;

    // Note sécurité
    if (data.securityHeaders) {
      var secGrade = data.securityHeaders.grade;
      var secEl = document.getElementById('security-grade-letter');
      secEl.textContent = secGrade;
      secEl.className = 'grade-letter ' + secGrade;
      displaySecurityHeaders(data.securityHeaders);
      displaySecurityDiagnostic(data.securityHeaders);
    }

    var lcp = audits['largest-contentful-paint'];
    var fid = audits['max-potential-fid'] || audits['total-blocking-time'];
    var cls = audits['cumulative-layout-shift'];

    updateVital('lcp', lcp.displayValue, lcp.score);
    updateVital('fid', fid.displayValue, fid.score);
    updateVital('cls', cls.displayValue, cls.score);

    var titleAudit = audits['document-title'];
    if (titleAudit) {
      var pageTitle = '';
      if (titleAudit.details && titleAudit.details.items && titleAudit.details.items.length > 0) {
        pageTitle = titleAudit.details.items[0].snippet || '';
      }
      if (!pageTitle && lighthouse.finalUrl) {
        try {
          var urlObj = new URL(lighthouse.finalUrl);
          pageTitle = urlObj.hostname;
        } catch (e) {
          pageTitle = lighthouse.finalUrl;
        }
      }
      if (pageTitle) {
        document.getElementById('meta-title').textContent = pageTitle;
        updateMetaLength('title', pageTitle.length);
      } else if (titleAudit.score === 1) {
        document.getElementById('meta-title').textContent = '✓ Présent';
      } else {
        document.getElementById('meta-title').textContent = '❌ Non trouvé';
      }
    }

    var metaDesc = audits['meta-description'];
    if (metaDesc) {
      if (metaDesc.score === 1) {
        document.getElementById('meta-description').textContent = '✓ Présente';
        document.getElementById('meta-description-length').textContent = '';
      } else {
        document.getElementById('meta-description').textContent = '❌ Manquante ou vide';
        document.getElementById('meta-description-length').textContent = '';
      }
    }

    document.getElementById('meta-og-image').textContent = 'Vérifier manuellement';

    var canonical = audits['canonical'];
    if (canonical && canonical.score === 1) {
      document.getElementById('meta-canonical').textContent = 'Présent ✓';
    } else {
      document.getElementById('meta-canonical').textContent = 'Non trouvé ❌';
    }

    displayRecommandations(audits);
  }

  function displaySecurityHeaders(securityData) {
    var list = document.getElementById('security-headers-list');
    if (!list || !securityData.results) return;

    list.innerHTML = '';

    securityData.results.forEach(function(h) {
      var item = document.createElement('div');
      item.className = 'security-header-item';
      item.innerHTML =
        '<span class="security-header-status">' + (h.present ? '✅' : '❌') + '</span>' +
        '<span class="security-header-label" style="color:#ffffff !important;">' + h.label + '</span>' +
        '<span class="security-header-badge ' + (h.present ? 'ok' : 'missing') + '">' +
          (h.present ? 'Présent' : 'Manquant') +
        '</span>';
      list.appendChild(item);
    });
  }

  function displaySecurityDiagnostic(securityData) {
    var card = document.getElementById('security-diagnostic-card');
    var header = document.getElementById('security-diagnostic-header');
    var items = document.getElementById('security-diagnostic-items');
    var cta = document.getElementById('security-diagnostic-cta');
    if (!card) return;

    card.style.display = 'block';
    var score = securityData.score || 0;
    var present = securityData.presentCount || 0;
    var total = securityData.total || 6;

    if (score >= 80) {
      card.className = 'result-card diagnostic-card green';
      header.innerHTML = '<span style="color:#ffffff">🟢 Votre site est bien sécurisé 🔒</span>';
      items.innerHTML = '<div class="diagnostic-item"><span>✔️</span><span style="color:#ffffff">Headers de sécurité présents</span></div><div class="diagnostic-item"><span>✔️</span><span style="color:#ffffff">Protection contre les attaques courantes</span></div><div class="diagnostic-item"><span>✔️</span><span style="color:#ffffff">Configuration serveur saine</span></div>';
      cta.innerHTML = "👉 " + present + "/" + total + " headers détectés. Votre site inspire confiance aux navigateurs et moteurs de recherche.";
    } else if (score >= 40) {
      card.className = 'result-card diagnostic-card orange';
      header.innerHTML = '<span style="color:#ffffff">🟠 Sécurité partielle — des risques existent.</span>';
      items.innerHTML = '<div class="diagnostic-item"><span>⚠️</span><span style="color:#ffffff">Certains headers manquants</span></div><div class="diagnostic-item"><span>⚠️</span><span style="color:#ffffff">Protection incomplète contre le phishing</span></div><div class="diagnostic-item"><span>⚠️</span><span style="color:#ffffff">Navigateurs non totalement protégés</span></div>';
      cta.innerHTML = "👉 " + present + "/" + total + " headers détectés. Quelques configurations simples suffisent à corriger ça.";
    } else {
      card.className = 'result-card diagnostic-card red';
      header.innerHTML = '<span style="color:#ffffff">🔴 Sécurité insuffisante — votre site est exposé.</span>';
      items.innerHTML = '<div class="diagnostic-item"><span>❌</span><span style="color:#ffffff">Headers de sécurité absents ou insuffisants</span></div><div class="diagnostic-item"><span>❌</span><span style="color:#ffffff">Risque de détournement de contenu (XSS, clickjacking)</span></div><div class="diagnostic-item"><span>❌</span><span style="color:#ffffff">Signal négatif pour Google et les navigateurs</span></div>';
      cta.innerHTML = "👉 " + present + "/" + total + " headers détectés. Une configuration serveur rapide peut tout corriger.";
    }
  }

  function displayDiagnostic(score) {
    var card = document.getElementById('diagnostic-card');
    var header = document.getElementById('diagnostic-header');
    var items = document.getElementById('diagnostic-items');
    var cta = document.getElementById('diagnostic-cta');

    card.style.display = 'block';

    if (score >= 85) {
      card.className = 'result-card diagnostic-card green';
      header.innerHTML = '<span style="color:#ffffff">🟢 Votre site est performant 👍</span>';
      items.innerHTML = '<div class="diagnostic-item"><span>✔️</span><span style="color:#ffffff">Bonne vitesse</span></div><div class="diagnostic-item"><span>✔️</span><span style="color:#ffffff">Structure correcte</span></div><div class="diagnostic-item"><span>✔️</span><span style="color:#ffffff">Bon potentiel SEO</span></div>';
      cta.innerHTML = '👉 Vous pouvez encore optimiser certains points pour dépasser vos concurrents.';
    } else if (score >= 60) {
      card.className = 'result-card diagnostic-card orange';
      header.innerHTML = '<span style="color:#ffffff">🟠 Votre site fonctionne… mais perd des opportunités.</span>';
      items.innerHTML = '<div class="diagnostic-item"><span>⚠️</span><span style="color:#ffffff">Chargement perfectible</span></div><div class="diagnostic-item"><span>⚠️</span><span style="color:#ffffff">Quelques freins SEO</span></div><div class="diagnostic-item"><span>⚠️</span><span style="color:#ffffff">Risque de perte de trafic</span></div>';
      cta.innerHTML = '👉 Des optimisations simples peuvent améliorer votre visibilité.';
    } else {
      card.className = 'result-card diagnostic-card red';
      header.innerHTML = '<span style="color:#ffffff">🔴 Votre site pénalise votre visibilité.</span>';
      items.innerHTML = '<div class="diagnostic-item"><span>❌</span><span style="color:#ffffff">Temps de chargement élevé</span></div><div class="diagnostic-item"><span>❌</span><span style="color:#ffffff">Structure SEO insuffisante</span></div><div class="diagnostic-item"><span>❌</span><span style="color:#ffffff">Risque de mauvaise expérience utilisateur</span></div>';
      cta.innerHTML = "👉 Une refonte technique s'impose pour ne plus perdre de visiteurs et de positions.";
    }
  }

  function updateScore(score, loadingExp) {
    var scoreFill = document.getElementById('score-fill');
    var scoreValue = document.getElementById('score-value');
    var scoreLabel = document.getElementById('score-label');
    var scoreHuman = document.getElementById('score-human');

    var circumference = 534;
    var offset = circumference - (score / 100) * circumference;

    scoreFill.style.strokeDashoffset = offset;
    scoreValue.textContent = score;

    var color, label;
    if (score >= 90) { color = '#10b981'; label = 'Excellent'; }
    else if (score >= 50) { color = '#f59e0b'; label = 'À améliorer'; }
    else { color = '#ef4444'; label = 'Faible'; }

    scoreFill.style.stroke = color;
    scoreLabel.textContent = label;

    if (scoreHuman) {
      var human = '';
      if (loadingExp && loadingExp.overall_category) {
        var cat = loadingExp.overall_category;
        if (cat === 'FAST') {
          human = "✅ Données terrain : votre site est rapide pour vos vrais visiteurs.";
        } else if (cat === 'AVERAGE') {
          human = "⚠️ Données terrain : votre site est moyen pour vos vrais visiteurs Chrome.";
        } else if (cat === 'SLOW') {
          human = "❌ Données terrain : votre site est lent pour vos vrais visiteurs Chrome.";
        }
        var fcp = loadingExp.metrics && loadingExp.metrics['FIRST_CONTENTFUL_PAINT_MS'];
        if (fcp && fcp.distributions && fcp.distributions[0]) {
          var pctFast = Math.round(fcp.distributions[0].proportion * 100);
          human += " " + pctFast + "% de vos visiteurs ont un chargement rapide.";
        }
      } else {
        if (score >= 90) {
          human = "Votre site charge vite — vos visiteurs ne perdent pas patience.";
        } else if (score >= 70) {
          human = "Votre site est correct, mais un chargement plus rapide pourrait améliorer l'expérience utilisateur.";
        } else if (score >= 50) {
          human = "Votre site est lent — vous perdez probablement des visiteurs avant même qu'ils voient votre contenu.";
        } else {
          human = "Votre site est lent — vous perdez probablement des visiteurs avant même qu'ils voient votre contenu.";
        }
      }
      scoreHuman.textContent = human;
    }
  }

  function updateVital(id, value, score) {
    document.getElementById(id + '-value').textContent = value;
    var status = document.getElementById(id + '-status');
    if (score >= 0.9) status.className = 'vital-status good';
    else if (score >= 0.5) status.className = 'vital-status needs-improvement';
    else status.className = 'vital-status poor';

    var humanEl = document.getElementById(id + '-human');
    if (!humanEl) return;
    var msg = '', cls = '';
    if (id === 'lcp') {
      if (score >= 0.9) { msg = "✅ Votre contenu principal s'affiche rapidement."; cls = 'good'; }
      else if (score >= 0.5) { msg = "⚠️ Votre page met trop de temps à afficher son contenu principal. Vos visiteurs peuvent partir."; cls = 'warn'; }
      else { msg = "❌ Temps de chargement trop long — vous perdez des visiteurs avant qu'ils voient votre site."; cls = 'bad'; }
    } else if (id === 'fid') {
      if (score >= 0.9) { msg = "✅ Votre page réagit rapidement aux actions des visiteurs."; cls = 'good'; }
      else if (score >= 0.5) { msg = "⚠️ Votre page met du temps à répondre aux clics — l'expérience peut sembler lente."; cls = 'warn'; }
      else { msg = "❌ Votre page est peu réactive — les visiteurs peuvent croire qu'elle est bloquée."; cls = 'bad'; }
    } else if (id === 'cls') {
      if (score >= 0.9) { msg = "✅ Votre mise en page est stable, rien ne bouge pendant le chargement."; cls = 'good'; }
      else if (score >= 0.5) { msg = "⚠️ Des éléments se déplacent pendant le chargement, ce qui perturbe la lecture."; cls = 'warn'; }
      else { msg = "❌ Votre page est instable visuellement — les boutons et textes bougent, ce qui frustre vos visiteurs."; cls = 'bad'; }
    }
    humanEl.textContent = msg;
    humanEl.className = 'vital-human ' + cls;
  }

  function toggleAccordion(id, btn) {
    var body = document.getElementById(id);
    var arrow = btn.querySelector('.accordion-arrow');
    if (body.style.display === 'none') {
      body.style.display = 'block';
      arrow.textContent = '▼ Masquer';
      arrow.classList.add('open');
    } else {
      body.style.display = 'none';
      arrow.textContent = '▶ Voir le détail';
      arrow.classList.remove('open');
    }
  }

  function updateMetaLength(type, length) {
    var el = document.getElementById('meta-' + type + '-length');
    if (!el) return;
    var status = '';
    if (type === 'title') {
      if (length >= 50 && length <= 60) { status = 'good'; el.textContent = length + ' caractères ✓'; }
      else { status = 'warning'; el.textContent = length + ' caractères (optimal: 50-60)'; }
    } else if (type === 'description') {
      if (length >= 150 && length <= 160) { status = 'good'; el.textContent = length + ' caractères ✓'; }
      else { status = 'warning'; el.textContent = length + ' caractères (optimal: 150-160)'; }
    }
    el.className = 'meta-length ' + status;
  }

