const form = document.getElementById('audit-form');
const urlInput = document.getElementById('url-input');
const analyzeBtn = document.getElementById('analyze-btn');
const btnText = analyzeBtn.querySelector('.btn-text');
const btnLoader = analyzeBtn.querySelector('.btn-loader');
const resultsDiv = document.getElementById('results');
const errorDiv = document.getElementById('error');

form?.addEventListener('submit', async (e) => {
  e.preventDefault();

  const url = urlInput.value.trim();
  if (!url) return;

  analyzeBtn.disabled = true;
  btnText.style.display = 'none';
  btnLoader.style.display = 'flex';
  resultsDiv.style.display = 'none';
  errorDiv.style.display = 'none';

  try {
    const response = await fetch('/api/audit.json', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ url })
    });

    const data = await response.json();

    if (!response.ok || data.error) {
      throw new Error(data.error || "Impossible d'analyser cette URL");
    }

    displayResults(data);
    resultsDiv.style.display = 'block';

  } catch (error) {
    console.error('Erreur:', error);
    document.getElementById('error-message').textContent = error.message;
    errorDiv.style.display = 'block';
  } finally {
    analyzeBtn.disabled = false;
    btnText.style.display = 'inline';
    btnLoader.style.display = 'none';
  }
});

function getSeverityIcon(score) {
  if (score >= 0.9) return '✅';
  if (score >= 0.5) return '⚠️';
  return '❌';
}

function displayResults(data) {
  const lighthouse = data.lighthouseResult;
  const categories = lighthouse.categories;
  const audits = lighthouse.audits;

  const perfScore = Math.round(categories.performance.score * 100);
  updateScore(perfScore);
  displayDiagnostic(perfScore);

  const lcp = audits['largest-contentful-paint'];
  const fid = audits['max-potential-fid'] || audits['total-blocking-time'];
  const cls = audits['cumulative-layout-shift'];

  updateVital('lcp', lcp.displayValue, lcp.score);
  updateVital('fid', fid.displayValue, fid.score);
  updateVital('cls', cls.displayValue, cls.score);

  const titleAudit = audits['document-title'];
  if (titleAudit) {
    let pageTitle = '';

    if (titleAudit.details && titleAudit.details.items && titleAudit.details.items.length > 0) {
      pageTitle = titleAudit.details.items[0].snippet || '';
    }

    if (!pageTitle && lighthouse.finalUrl) {
      try {
        const urlObj = new URL(lighthouse.finalUrl);
        pageTitle = urlObj.hostname;
      } catch (e) {
        pageTitle = lighthouse.finalUrl;
      }
    }

    if (pageTitle) {
      document.getElementById('meta-title').textContent = pageTitle;
      updateMetaLength('title', pageTitle.length);
    } else if (titleAudit.score === 1) {
      document.getElementById('meta-title').textContent = '✓ Présent';
    } else {
      document.getElementById('meta-title').textContent = '❌ Non trouvé';
    }
  }

  const metaDesc = audits['meta-description'];
  if (metaDesc) {
    if (metaDesc.score === 1) {
      document.getElementById('meta-description').textContent = '✓ Présente';
      document.getElementById('meta-description-length').textContent = '';
    } else {
      document.getElementById('meta-description').textContent = '❌ Manquante ou vide';
      document.getElementById('meta-description-length').textContent = '';
    }
  }

  document.getElementById('meta-og-image').textContent = 'Vérifier manuellement';

  const canonical = audits['canonical'];
  if (canonical && canonical.score === 1) {
    document.getElementById('meta-canonical').textContent = 'Présent ✓';
  } else {
    document.getElementById('meta-canonical').textContent = 'Non trouvé ❌';
  }

  displayRecommandations(audits);
}

function displayDiagnostic(score) {
  const card = document.getElementById('diagnostic-card');
  const header = document.getElementById('diagnostic-header');
  const items = document.getElementById('diagnostic-items');
  const cta = document.getElementById('diagnostic-cta');

  card.style.display = 'block';

  if (score >= 85) {
    card.className = 'result-card diagnostic-card green';
    header.innerHTML = '<span>🟢 Votre site est performant 👍</span>';
    items.innerHTML = `
      <div class="diagnostic-item"><span>✔️</span> <span>Bonne vitesse</span></div>
      <div class="diagnostic-item"><span>✔️</span> <span>Structure correcte</span></div>
      <div class="diagnostic-item"><span>✔️</span> <span>Bon potentiel SEO</span></div>
    `;
    cta.innerHTML = '👉 Vous pouvez encore optimiser certains points pour dépasser vos concurrents.';
  } else if (score >= 60) {
    card.className = 'result-card diagnostic-card orange';
    header.innerHTML = '<span>🟠 Votre site fonctionne… mais perd des opportunités.</span>';
    items.innerHTML = `
      <div class="diagnostic-item"><span>⚠️</span> <span>Chargement perfectible</span></div>
      <div class="diagnostic-item"><span>⚠️</span> <span>Quelques freins SEO</span></div>
      <div class="diagnostic-item"><span>⚠️</span> <span>Risque de perte de trafic</span></div>
    `;
    cta.innerHTML = '👉 Des optimisations simples peuvent améliorer votre visibilité.';
  } else {
    card.className = 'result-card diagnostic-card red';
    header.innerHTML = '<span>🔴 Votre site pénalise votre visibilité.</span>';
    items.innerHTML = `
      <div class="diagnostic-item"><span>❌</span> <span>Temps de chargement élevé</span></div>
      <div class="diagnostic-item"><span>❌</span> <span>Structure SEO insuffisante</span></div>
      <div class="diagnostic-item"><span>❌</span> <span>Risque de mauvaise expérience utilisateur</span></div>
    `;
    cta.innerHTML = "👉 Une refonte technique s'impose pour ne plus perdre de visiteurs et de positions.";
  }
}

function updateScore(score) {
  const scoreFill = document.getElementById('score-fill');
  const scoreValue = document.getElementById('score-value');
  const scoreLabel = document.getElementById('score-label');

  const circumference = 534;
  const offset = circumference - (score / 100) * circumference;

  scoreFill.style.strokeDashoffset = offset;
  scoreValue.textContent = score;

  let color, label;
  if (score >= 90) {
    color = '#10b981';
    label = 'Excellent';
  } else if (score >= 50) {
    color = '#f59e0b';
    label = 'À améliorer';
  } else {
    color = '#ef4444';
    label = 'Faible';
  }

  scoreFill.style.stroke = color;
  scoreLabel.textContent = label;
}

function updateVital(id, value, score) {
  document.getElementById(`${id}-value`).textContent = value;
  const status = document.getElementById(`${id}-status`);

  if (score >= 0.9) {
    status.className = 'vital-status good';
  } else if (score >= 0.5) {
    status.className = 'vital-status needs-improvement';
  } else {
    status.className = 'vital-status poor';
  }
}

function updateMetaLength(type, length) {
  const el = document.getElementById(`meta-${type}-length`);
  if (!el) return;

  let status = '';

  if (type === 'title') {
    if (length >= 50 && length <= 60) {
      status = 'good';
      el.textContent = `${length} caractères ✓`;
    } else {
      status = 'warning';
      el.textContent = `${length} caractères (optimal: 50-60)`;
    }
  } else if (type === 'description') {
    if (length >= 150 && length <= 160) {
      status = 'good';
      el.textContent = `${length} caractères ✓`;
    } else {
      status = 'warning';
      el.textContent = `${length} caractères (optimal: 150-160)`;
    }
  }

  el.className = `meta-length ${status}`;
}

