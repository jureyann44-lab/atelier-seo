    "avoid an excessive dom size": "Votre page contient trop d'éléments HTML, ce qui ralentit le navigateur.",
    "avoid multiple page redirects": "Des redirections inutiles allongent le temps de chargement.",
    "preconnect to required origins": "Des connexions externes pourraient être établies plus tôt.",
    "minimize main-thread work": "Le navigateur est surchargé de travail pendant le chargement.",
    "reduce javascript execution time": "L'exécution de votre JavaScript prend trop de temps.",
    "ensure text remains visible during webfont load": "Vos polices bloquent l'affichage du texte pendant leur chargement.",
    "avoid large layout shifts": "Des éléments bougent pendant le chargement et perturbent la lecture.",
    "reduce the impact of third-party code": "Des scripts tiers ralentissent votre site.",
    "minimize third-party usage": "Trop de scripts tiers impactent les performances.",
    "uses http/2": "Votre serveur n'utilise pas HTTP/2, une version plus rapide du protocole.",
    "avoid serving legacy javascript to modern browsers": "Du JavaScript obsolète est envoyé à des navigateurs modernes.",
    "image elements have explicit width and height": "Des images sans dimensions provoquent des décalages visuels.",
    "keep request counts low and transfer sizes small": "Trop de requêtes réseau alourdissent le chargement.",
    "preload key requests": "Certaines ressources importantes pourraient être chargées plus tôt.",
    "lazy load third-party resources with facades": "Des scripts tiers pourraient être chargés en différé.",
    "largest contentful paint image was lazily loaded": "L'image principale est chargée en différé.",
    "preload largest contentful paint image": "L'image principale de la page n'est pas préchargée."
  };

  const important = [];

  Object.keys(audits).forEach(key => {
    const audit = audits[key];
    if (audit.score !== null && audit.score !== undefined && audit.score < 0.9 && audit.title) {
      // Lookup par ID en priorité, puis par titre en lowercase (insensible à la casse)
      const titleLower = audit.title.toLowerCase();
      const titreFr = traductionsById[key]
        || traductionsByTitle[titleLower]
        || audit.title;

      important.push({
        title: titreFr,
        key: key,
        originalTitle: audit.title,
        score: audit.score
      });
    }
  });

  important.sort((a, b) => a.score - b.score);

  const toShow = important.slice(0, 8);

  if (toShow.length > 0) {
    toShow.forEach(rec => {
      const div = document.createElement('div');
      div.className = 'recommendation-item';
      const severityIcon = getSeverityIcon(rec.score);
      // Lookup description par ID en priorité, puis par titre en lowercase
      const originalTitleLower = rec.originalTitle?.toLowerCase() || '';
      const desc = descriptionsById[rec.key]
        || descByTitle[originalTitleLower]
        || '';

      div.innerHTML = `
        <span class="recommendation-icon">${severityIcon}</span>
        <div class="recommendation-content">
          <span class="recommendation-text">${rec.title}</span>
          ${desc ? `<span class="recommendation-desc">${desc}</span>` : ''}
        </div>
      `;
      container.appendChild(div);
    });
  } else {
    container.innerHTML = '<p style="color: #9ca3af; text-align: center;">Aucune recommandation majeure. Votre site est bien optimisé ! ✓</p>';
  }
}