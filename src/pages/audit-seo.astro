---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const title = "Audit SEO Gratuit | Analyseur de Performance Web | Habeprod";
const description = "Analysez gratuitement les performances SEO de votre site : Core Web Vitals, meta tags, vitesse de chargement. Audit complet en temps réel.";
const canonical = "https://www.habeprod-agence.fr/audit-seo";
---

<Layout 
  title={title} 
  description={description}
  canonical={canonical}
  ogType="website"
>
  <Nav />
  
  <main class="audit-page">
    <section class="audit-hero">
      <div class="container">
        <span class="hero-label">TESTEZ VOTRE SITE GRATUITEMENT</span>
        <h1>Audit SEO <span class="highlight">en temps réel</span></h1>
        <p class="hero-subtitle">
          Analysez les performances de votre site web : Core Web Vitals, meta tags, et recommandations d'optimisation.
        </p>
      </div>
    </section>

    <section class="audit-tool">
      <div class="container">
        
        <!-- FORMULAIRE -->
        <div class="audit-form-card">
          <h2>Entrez l'URL de votre site</h2>
          <form id="audit-form">
            <div class="input-group">
              <input 
                type="url" 
                id="url-input" 
                placeholder="https://exemple.com" 
                required
                pattern="https?://.+"
              />
              <button type="submit" id="analyze-btn">
                <span class="btn-text">Analyser</span>
                <span class="btn-loader" style="display: none;">
                  <span class="spinner"></span>
                  Analyse en cours...
                </span>
              </button>
            </div>
            <p class="form-note">L'analyse prend environ 10-15 secondes</p>
            <p class="security-note">🔒 Analyse sécurisée – aucune donnée stockée</p>
          </form>
        </div>

        <!-- RÉSULTATS -->
        <div id="results" style="display: none;">
          
          <!-- SCORE GLOBAL -->
          <div class="result-card score-card">
            <h3>Score de performance</h3>
            <div class="score-circle" id="score-circle">
              <svg viewBox="0 0 200 200">
                <circle class="score-bg" cx="100" cy="100" r="85"></circle>
                <circle class="score-fill" cx="100" cy="100" r="85" id="score-fill"></circle>
              </svg>
              <div class="score-value" id="score-value">--</div>
            </div>
            <p class="score-label" id="score-label">Chargement...</p>
            <p class="score-human" id="score-human"></p>
          </div>

          <!-- NOTES VITESSE + SÉCURITÉ -->
          <div class="grades-row">
            <div class="grade-card">
              <div class="grade-icon">⚡</div>
              <div class="grade-info">
                <span class="grade-title">Vitesse</span>
                <span class="grade-subtitle">Google PageSpeed</span>
              </div>
              <div class="grade-letter" id="speed-grade-letter">--</div>
            </div>
            <div class="grade-card">
              <div class="grade-icon">🔒</div>
              <div class="grade-info">
                <span class="grade-title">Sécurité</span>
                <span class="grade-subtitle">Headers HTTP</span>
              </div>
              <div class="grade-letter" id="security-grade-letter">--</div>
            </div>
          </div>

          <!-- DIAGNOSTIC BLOC -->
          <div class="result-card diagnostic-card" id="diagnostic-card" style="display: none;">
            <div class="diagnostic-header" id="diagnostic-header"></div>
            <div class="diagnostic-items" id="diagnostic-items"></div>
            <div class="diagnostic-cta" id="diagnostic-cta"></div>
          </div>

          <!-- DIAGNOSTIC SÉCURITÉ -->
          <div class="result-card diagnostic-card" id="security-diagnostic-card" style="display: none;">
            <div class="diagnostic-header" id="security-diagnostic-header"></div>
            <div class="diagnostic-items" id="security-diagnostic-items"></div>
            <div class="diagnostic-cta" id="security-diagnostic-cta"></div>
          </div>

          <!-- CTA INLINE -->
          <div class="inline-cta" id="inline-cta" style="display:none;">
            <h2>Besoin d'aide pour optimiser votre site ?</h2>
            <p>Notre équipe peut vous accompagner dans l'amélioration de vos performances SEO.</p>
            <a href="/#contact" class="cta-btn">On m'explique tout →</a>
          </div>

          <!-- CORE WEB VITALS — pliable -->
          <div class="result-card accordion-card">
            <button class="accordion-toggle" onclick="toggleAccordion('vitals-body', this)">
              <span>⚡ Core Web Vitals</span>
              <span class="accordion-arrow">▶ Voir le détail</span>
            </button>
            <div class="accordion-body" id="vitals-body" style="display:none;">
              <div class="vitals-grid">
                <div class="vital-item">
                  <div class="vital-icon">⚡</div>
                  <div class="vital-info">
                    <span class="vital-label">LCP</span>
                    <span class="vital-desc">Largest Contentful Paint</span>
                  </div>
                  <div class="vital-value" id="lcp-value">--</div>
                  <div class="vital-status" id="lcp-status"></div>
                </div>
                <p class="vital-human" id="lcp-human"></p>
                <div class="vital-item">
                  <div class="vital-icon">🎯</div>
                  <div class="vital-info">
                    <span class="vital-label">FID / TBT</span>
                    <span class="vital-desc">Réactivité de la page</span>
                  </div>
                  <div class="vital-value" id="fid-value">--</div>
                  <div class="vital-status" id="fid-status"></div>
                </div>
                <p class="vital-human" id="fid-human"></p>
                <div class="vital-item">
                  <div class="vital-icon">📐</div>
                  <div class="vital-info">
                    <span class="vital-label">CLS</span>
                    <span class="vital-desc">Cumulative Layout Shift</span>
                  </div>
                  <div class="vital-value" id="cls-value">--</div>
                  <div class="vital-status" id="cls-status"></div>
                </div>
                <p class="vital-human" id="cls-human"></p>
              </div>
            </div>
          </div>

          <!-- META TAGS — pliable -->
          <div class="result-card accordion-card">
            <button class="accordion-toggle" onclick="toggleAccordion('meta-body', this)">
              <span>🏷️ Meta Tags SEO</span>
              <span class="accordion-arrow">▶ Voir le détail</span>
            </button>
            <div class="accordion-body" id="meta-body" style="display:none;">
              <div class="meta-list">
                <div class="meta-item">
                  <span class="meta-label">Title</span>
                  <span class="meta-value" id="meta-title">--</span>
                  <span class="meta-length" id="meta-title-length"></span>
                </div>
                <div class="meta-item">
                  <span class="meta-label">Description</span>
                  <span class="meta-value" id="meta-description">--</span>
                  <span class="meta-length" id="meta-description-length"></span>
                </div>
                <div class="meta-item">
                  <span class="meta-label">OG:Image</span>
                  <span class="meta-value" id="meta-og-image">--</span>
                </div>
                <div class="meta-item">
                  <span class="meta-label">Canonical</span>
                  <span class="meta-value" id="meta-canonical">--</span>
                </div>
              </div>
            </div>
          </div>

          <!-- HEADERS SÉCURITÉ — pliable -->
          <div class="result-card accordion-card">
            <button class="accordion-toggle" onclick="toggleAccordion('security-body', this)">
              <span>🔒 Headers de sécurité</span>
              <span class="accordion-arrow">▶ Voir le détail</span>
            </button>
            <div class="accordion-body" id="security-body" style="display:none;">
              <div id="security-headers-list" class="security-list"></div>
            </div>
          </div>

          <!-- RECOMMANDATIONS — pliable -->
          <div class="result-card accordion-card">
            <button class="accordion-toggle" onclick="toggleAccordion('reco-body', this)">
              <span>🎯 Recommandations prioritaires</span>
              <span class="accordion-arrow">▶ Voir le détail</span>
            </button>
            <div class="accordion-body" id="reco-body" style="display:none;">
              <div id="recommendations" class="recommendations-list"></div>
            </div>
          </div>

        </div>

        <!-- BLOC AIDE -->
        <div id="help-block" style="display: none;">
          <div class="result-card" style="text-align: center; border-color: #2a2a2a;">
            <p style="font-size: 1.5rem; margin-bottom: 8px;">🤯</p>
            <p style="color: #ffffff; font-size: 1rem; font-weight: 600; margin-bottom: 8px;">
              Ces résultats ressemblent à du chinois ?
            </p>
            <p style="color: #9ca3af; font-size: 0.9rem; margin-bottom: 0;">
              C'est normal, on ne vous a pas encore appris à lire le Lighthouse. Envoyez-nous l'URL et on vous explique tout ça en humain. 🧑‍💻
            </p>
          </div>
        </div>

        <!-- ERREUR -->
        <div id="error" class="error-card" style="display: none;">
          <span class="error-icon">⚠️</span>
          <h3>Erreur d'analyse</h3>
          <p id="error-message"></p>
          <button onclick="document.getElementById('error').style.display='none'">Réessayer</button>
        </div>

      </div>
    </section>



    <!-- BOUTON RETOUR -->
    <section class="back-home-section">
      <div class="container">
        <a href="/" class="back-to-home">
          <span class="back-arrow">←</span>
          <span class="back-text">Retour à l'accueil</span>
        </a>
      </div>
    </section>

  </main>

  <Footer />
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Comment fonctionne l'audit SEO gratuit ?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Notre outil analyse votre site en temps réel via Google PageSpeed Insights. Il vérifie les Core Web Vitals, les meta tags, la vitesse de chargement et les headers de sécurité."
          }
        },
        {
          "@type": "Question",
          "name": "Combien de temps dure l'analyse SEO ?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "L'analyse prend environ 10 à 15 secondes. Vous obtenez un rapport complet avec un score de performance et des recommandations prioritaires."
          }
        },
        {
          "@type": "Question",
          "name": "L'audit SEO est-il vraiment gratuit ?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Oui, l'audit est entièrement gratuit et sans inscription. Aucune donnée n'est stockée."
          }
        },
        {
          "@type": "Question",
          "name": "Que sont les Core Web Vitals ?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Les Core Web Vitals sont trois métriques Google : le LCP, le TBT et le CLS. Ils influencent directement votre position dans les résultats de recherche."
          }
        }
      ]
    })} />
  </Fragment>
</Layout>

<style>
  :root {
    --orange: #ea6432;
    --black: #000000;
    --white: #ffffff;
    --gray: #9ca3af;
    --dark-card: #1a1a1a;
    --green: #10b981;
    --yellow: #f59e0b;
    --red: #ef4444;
  }

  .audit-page {
    background: var(--black);
    padding-top: 100px;
  }

  .container {
    max-width: var(--layout-width);
    margin: 0 auto;
    padding: 0 var(--gutter);
  }

  .audit-hero {
    padding: 80px 0 0 !important;
    text-align: left;
  }

  .hero-label {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--gray);
    margin-bottom: 16px;
  }

  .audit-hero h1 {
    font-size: 2.5rem;
    font-weight: 600;
    margin-bottom: 20px;
    color: var(--white);
  }

  .highlight { color: var(--orange); }

  .hero-subtitle {
    font-size: 1.1rem;
    color: var(--gray);
    max-width: 600px;
  }

  .audit-tool { padding: 80px 0 0 !important; }

  .audit-form-card {
    background: var(--dark-card);
    border: 2px solid #2a2a2a;
    border-radius: 16px;
    padding: 48px;
    margin-bottom: 40px;
  }

  .audit-form-card h2 {
    font-size: 1.5rem;
    color: var(--white);
    margin-bottom: 24px;
    text-align: center;
  }

  .input-group {
    display: flex;
    gap: 12px;
    max-width: 700px;
    margin: 0 auto;
  }

  #url-input {
    flex: 1;
    padding: 16px 24px;
    background: var(--black);
    border: 2px solid #2a2a2a;
    border-radius: 12px;
    color: var(--white);
    font-size: 1rem;
    transition: border-color 0.3s;
  }

  #url-input:focus {
    outline: none;
    border-color: var(--orange);
  }

  #analyze-btn {
    padding: 16px 48px;
    background: var(--orange);
    color: var(--white);
    border: none;
    border-radius: 12px;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s;
    white-space: nowrap;
  }

  #analyze-btn:hover { background: #d4581f; transform: translateY(-2px); }
  #analyze-btn:disabled { opacity: 0.6; cursor: not-allowed; transform: none; }

  .spinner {
    display: inline-block;
    width: 16px;
    height: 16px;
    border: 2px solid rgba(255,255,255,0.3);
    border-top-color: white;
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
  }

  @keyframes spin { to { transform: rotate(360deg); } }

  .form-note {
    text-align: center;
    font-size: 0.85rem;
    color: var(--gray);
    margin-top: 12px;
    margin-bottom: 0;
  }

  .security-note {
    text-align: right;
    font-size: 0.78rem;
    color: var(--gray);
    margin-top: 10px;
    margin-bottom: 0;
    letter-spacing: 0.01em;
  }

  .result-card {
    background: var(--dark-card);
    border: 2px solid #2a2a2a;
    border-radius: 16px;
    padding: 32px;
    margin-bottom: 24px;
  }

  .result-card h3 {
    font-size: 1.3rem;
    color: var(--white);
    margin-bottom: 24px;
  }

  /* SCORE */
  .score-card { text-align: center; }

  .score-circle {
    position: relative;
    width: 200px;
    height: 200px;
    margin: 0 auto 20px;
  }

  .score-circle svg { transform: rotate(-90deg); }
  .score-bg { fill: none; stroke: #2a2a2a; stroke-width: 12; }

  .score-fill {
    fill: none;
    stroke: var(--orange);
    stroke-width: 12;
    stroke-linecap: round;
    stroke-dasharray: 534;
    stroke-dashoffset: 534;
    transition: stroke-dashoffset 1s ease, stroke 0.5s;
  }

  .score-value {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-size: 3rem;
    font-weight: 700;
    color: var(--white);
  }

  .score-label { font-size: 1.1rem; color: var(--gray); }

  .score-human {
    font-size: 0.9rem;
    color: #ffffff !important;
    margin-top: 8px;
    font-style: italic;
    max-width: 280px;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.5;
  }
  .score-human.good { color: #ffffff !important; }
  .score-human.warn { color: #ffffff !important; }
  .score-human.bad  { color: #ffffff !important; }

  /* NOTES VITESSE + SÉCURITÉ */
  .grades-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-bottom: 24px;
  }

  .grade-card {
    background: var(--dark-card);
    border: 2px solid #2a2a2a;
    border-radius: 16px;
    padding: 24px;
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .grade-icon { font-size: 2rem; flex-shrink: 0; }

  .grade-info {
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .grade-title {
    font-size: 1rem;
    font-weight: 600;
    color: var(--white);
  }

  .grade-subtitle {
    font-size: 0.78rem;
    color: var(--gray);
    margin-top: 2px;
  }

  .grade-letter {
    font-size: 2.8rem;
    font-weight: 800;
    min-width: 48px;
    text-align: center;
    color: var(--gray);
    transition: color 0.4s;
    line-height: 1;
  }

  .grade-letter.A { color: #10b981; }
  .grade-letter.B { color: #34d399; }
  .grade-letter.C { color: #f59e0b; }
  .grade-letter.D { color: #f97316; }
  .grade-letter.F { color: #ef4444; }

  /* DIAGNOSTIC — plus imposant */
  .diagnostic-card {
    padding: 36px 40px;
    border-radius: 20px;
    border-width: 2px;
    border-style: solid;
    margin-bottom: 32px;
  }

  .diagnostic-card.green { background: rgba(16, 185, 129, 0.1); border-color: rgba(16, 185, 129, 0.4); }
  .diagnostic-card.orange { background: rgba(245, 158, 11, 0.1); border-color: rgba(245, 158, 11, 0.4); }
  .diagnostic-card.red { background: rgba(239, 68, 68, 0.1); border-color: rgba(239, 68, 68, 0.4); }

  .diagnostic-header {
    font-size: 1.35rem;
    font-weight: 700;
    color: #ffffff !important;
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .diagnostic-items {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-bottom: 20px;
  }

  .diagnostic-item {
    font-size: 1rem;
    color: #ffffff !important;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  /* ACCORDÉONS */
  .accordion-card {
    padding: 0 !important;
    overflow: hidden;
  }

  .accordion-toggle {
    width: 100%;
    background: none;
    border: none;
    padding: 24px 32px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    cursor: pointer;
    color: var(--white);
    font-size: 1.1rem;
    font-weight: 600;
    text-align: left;
    transition: background 0.2s;
  }

  .accordion-toggle:hover { background: rgba(255,255,255,0.04); }

  .accordion-arrow {
    font-size: 0.8rem;
    color: var(--orange);
    font-weight: 600;
    white-space: nowrap;
    transition: all 0.2s;
  }

  .accordion-arrow.open {
    color: var(--gray);
  }

  .accordion-body {
    padding: 0 32px 28px 32px;
    border-top: 1px solid #2a2a2a;
  }

  /* PHRASES HUMAINES VITALS */
  .vital-human {
    font-size: 0.85rem;
    color: #9ca3af;
    font-style: italic;
    margin: -8px 0 12px 52px;
    line-height: 1.5;
  }

  .vital-human.bad { color: #fca5a5; }
  .vital-human.warn { color: #fcd34d; }
  .vital-human.good { color: #6ee7b7; }

  .diagnostic-item span,
  .diagnostic-header span { color: #ffffff !important; }

  .diagnostic-cta {
    font-size: 0.9rem;
    color: var(--gray);
    padding-top: 14px;
    border-top: 1px solid #2a2a2a;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  /* VITALS */
  .vitals-grid { display: grid; gap: 20px; }

  .vital-item {
    display: grid;
    grid-template-columns: auto 1fr auto auto;
    gap: 16px;
    align-items: center;
    padding: 20px;
    background: var(--black);
    border-radius: 12px;
  }

  .vital-icon { font-size: 2rem; }
  .vital-info { display: flex; flex-direction: column; }
  .vital-label { font-size: 1rem; font-weight: 600; color: var(--white); }
  .vital-desc { font-size: 0.85rem; color: var(--gray); }
  .vital-value { font-size: 1.5rem; font-weight: 700; color: var(--white); }
  .vital-status { width: 12px; height: 12px; border-radius: 50%; }
  .vital-status.good { background: var(--green); }
  .vital-status.needs-improvement { background: var(--yellow); }
  .vital-status.poor { background: var(--red); }

  /* META */
  .meta-list { display: grid; gap: 16px; }

  .meta-item {
    display: grid;
    grid-template-columns: 120px 1fr auto;
    gap: 16px;
    align-items: start;
    padding: 16px;
    background: var(--black);
    border-radius: 8px;
  }

  .meta-label { font-weight: 600; color: var(--orange); font-size: 0.9rem; }
  .meta-value { color: var(--white); word-break: break-word; }
  .meta-length { font-size: 0.85rem; color: var(--gray); white-space: nowrap; }
  .meta-length.good { color: var(--green); }
  .meta-length.warning { color: var(--yellow); }

  /* HEADERS SÉCURITÉ */
  .security-list { display: grid; gap: 10px; }

  .security-header-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px 16px;
    background: var(--black);
    border-radius: 8px;
  }

  .security-header-status { font-size: 1rem; flex-shrink: 0; width: 20px; text-align: center; }

  .security-header-label {
    font-size: 0.9rem;
    color: #ffffff !important;
    flex: 1;
  }

  .security-header-badge {
    font-size: 0.75rem;
    font-weight: 600;
    padding: 3px 10px;
    border-radius: 999px;
  }

  .security-header-badge.ok {
    background: rgba(16, 185, 129, 0.15);
    color: #10b981;
  }

  .security-header-badge.missing {
    background: rgba(239, 68, 68, 0.15);
    color: #ef4444;
  }

  /* RECOMMANDATIONS */
  .recommendations-list { display: grid; gap: 12px; }

  .recommendation-item {
    display: flex;
    gap: 12px;
    padding: 16px;
    background: var(--black);
    border-radius: 8px;
    border-left: 3px solid var(--orange);
  }

  .recommendation-icon { font-size: 1.2rem; flex-shrink: 0; }

  .recommendation-content {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .recommendation-text {
    color: #ffffff !important;
    line-height: 1.6;
    font-size: 0.95rem;
    margin: 0;
  }

  .recommendation-desc {
    font-size: 0.82rem;
    color: #9ca3af !important;
    line-height: 1.5;
    font-style: italic;
    margin: 0;
  }

  /* ERREUR */
  .error-card {
    background: rgba(239, 68, 68, 0.1);
    border: 2px solid var(--red);
    border-radius: 16px;
    padding: 48px;
    text-align: center;
