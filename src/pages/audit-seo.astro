  function updateScore(score) {
    var scoreFill = document.getElementById('score-fill');
    var scoreValue = document.getElementById('score-value');
    var scoreLabel = document.getElementById('score-label');

    var circumference = 534;
    var offset = circumference - (score / 100) * circumference;

    scoreFill.style.strokeDashoffset = offset;
    scoreValue.textContent = score;

    var color, label;
    if (score >= 90) {
      color = '#10b981';
      label = 'Excellent';
    } else if (score >= 50) {
      color = '#f59e0b';
      label = 'À améliorer';
    } else {
      color = '#ef4444';
      label = 'Faible';
    }

    scoreFill.style.stroke = color;
    scoreLabel.textContent = label;
  }

  function updateVital(id, value, score) {
    document.getElementById(id + '-value').textContent = value;
    var status = document.getElementById(id + '-status');

    if (score >= 0.9) {
      status.className = 'vital-status good';
    } else if (score >= 0.5) {
      status.className = 'vital-status needs-improvement';
    } else {
      status.className = 'vital-status poor';
    }
  }

  function updateMetaLength(type, length) {
    var el = document.getElementById('meta-' + type + '-length');
    if (!el) return;

    var status = '';

    if (type === 'title') {
      if (length >= 50 && length <= 60) {
        status = 'good';
        el.textContent = length + ' caractères ✓';
      } else {
        status = 'warning';
        el.textContent = length + ' caractères (optimal: 50-60)';
      }
    } else if (type === 'description') {
      if (length >= 150 && length <= 160) {
        status = 'good';
        el.textContent = length + ' caractères ✓';
      } else {
        status = 'warning';
        el.textContent = length + ' caractères (optimal: 150-160)';
      }
    }

    el.className = 'meta-length ' + status;
  }

