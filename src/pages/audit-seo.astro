---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const title = "Audit SEO Gratuit | Analyseur de Performance Web | Habeprod";
const description = "Analysez gratuitement les performances SEO de votre site : Core Web Vitals, meta tags, vitesse de chargement. Audit complet en temps réel.";
const canonical = "https://www.habeprod-agence.fr/audit-seo";
---

<Layout 
  title={title} 
  description={description}
  canonical={canonical}
  ogType="website"
>
  <Nav />
  
  <main class="audit-page">
    <section class="audit-hero">
      <div class="container">
        <span class="hero-label">Outil gratuit</span>
        <h1>Audit SEO <span class="highlight">en temps réel</span></h1>
        <p class="hero-subtitle">
          Analysez les performances de votre site web : Core Web Vitals, meta tags, et recommandations d'optimisation.
        </p>
      </div>
    </section>

    <section class="audit-tool">
      <div class="container">
        
        <!-- FORMULAIRE -->
        <div class="audit-form-card">
          <h2>Entrez l'URL de votre site</h2>
          <form id="audit-form">
            <div class="input-group">
              <input 
                type="url" 
                id="url-input" 
                placeholder="https://exemple.com" 
                required
                pattern="https?://.+"
              />
              <button type="submit" id="analyze-btn">
                <span class="btn-text">Analyser</span>
                <span class="btn-loader" style="display: none;">
                  <span class="spinner"></span>
                  Analyse en cours...
                </span>
              </button>
            </div>
            <p class="form-note">L'analyse prend environ 10-15 secondes</p>
            <p class="security-note">🔒 Analyse sécurisée – aucune donnée stockée</p>
          </form>
        </div>

        <!-- RÉSULTATS -->
        <div id="results" style="display: none;">
          
          <!-- SCORE GLOBAL -->
          <div class="result-card score-card">
            <h3>Score de performance</h3>
            <div class="score-circle" id="score-circle">
              <svg viewBox="0 0 200 200">
                <circle class="score-bg" cx="100" cy="100" r="85"></circle>
                <circle class="score-fill" cx="100" cy="100" r="85" id="score-fill"></circle>
              </svg>
              <div class="score-value" id="score-value">--</div>
            </div>
            <p class="score-label" id="score-label">Chargement...</p>
          </div>

          <!-- DIAGNOSTIC BLOC -->
          <div class="result-card diagnostic-card" id="diagnostic-card" style="display: none;">
            <div class="diagnostic-header" id="diagnostic-header"></div>
            <div class="diagnostic-items" id="diagnostic-items"></div>
            <div class="diagnostic-cta" id="diagnostic-cta"></div>
          </div>

          <!-- CORE WEB VITALS -->
          <div class="result-card">
            <h3>Core Web Vitals</h3>
            <div class="vitals-grid">
              <div class="vital-item">
                <div class="vital-icon">⚡</div>
                <div class="vital-info">
                  <span class="vital-label">LCP</span>
                  <span class="vital-desc">Largest Contentful Paint</span>
                </div>
                <div class="vital-value" id="lcp-value">--</div>
                <div class="vital-status" id="lcp-status"></div>
              </div>
              <div class="vital-item">
                <div class="vital-icon">🎯</div>
                <div class="vital-info">
                  <span class="vital-label">FID</span>
                  <span class="vital-desc">First Input Delay</span>
                </div>
                <div class="vital-value" id="fid-value">--</div>
                <div class="vital-status" id="fid-status"></div>
              </div>
              <div class="vital-item">
                <div class="vital-icon">📐</div>
                <div class="vital-info">
                  <span class="vital-label">CLS</span>
                  <span class="vital-desc">Cumulative Layout Shift</span>
                </div>
                <div class="vital-value" id="cls-value">--</div>
                <div class="vital-status" id="cls-status"></div>
              </div>
            </div>
          </div>

          <!-- META TAGS -->
          <div class="result-card">
            <h3>Meta Tags SEO</h3>
            <div class="meta-list">
              <div class="meta-item">
                <span class="meta-label">Title</span>
                <span class="meta-value" id="meta-title">--</span>
                <span class="meta-length" id="meta-title-length"></span>
              </div>
              <div class="meta-item">
                <span class="meta-label">Description</span>
                <span class="meta-value" id="meta-description">--</span>
                <span class="meta-length" id="meta-description-length"></span>
              </div>
              <div class="meta-item">
                <span class="meta-label">OG:Image</span>
                <span class="meta-value" id="meta-og-image">--</span>
              </div>
              <div class="meta-item">
                <span class="meta-label">Canonical</span>
                <span class="meta-value" id="meta-canonical">--</span>
              </div>
            </div>
          </div>

          <!-- RECOMMANDATIONS -->
          <div class="result-card">
            <h3>Recommandations prioritaires</h3>
            <div id="recommendations" class="recommendations-list"></div>
          </div>

        </div>

        <!-- BLOC AIDE — sans bouton -->
        <div id="help-block" style="display: none;">
          <div class="result-card" style="text-align: center; border-color: #2a2a2a;">
            <p style="font-size: 1.5rem; margin-bottom: 8px;">🤯</p>
            <p style="color: #ffffff; font-size: 1rem; font-weight: 600; margin-bottom: 8px;">
              Ces résultats ressemblent à du chinois ?
            </p>
            <p style="color: #9ca3af; font-size: 0.9rem; margin-bottom: 0;">
              C'est normal, on ne vous a pas encore appris à lire le Lighthouse. Envoyez-nous l'URL et on vous explique tout ça en humain. 🧑‍💻
            </p>
          </div>
        </div>

        <!-- ERREUR -->
        <div id="error" class="error-card" style="display: none;">
          <span class="error-icon">⚠️</span>
          <h3>Erreur d'analyse</h3>
          <p id="error-message"></p>
          <button onclick="document.getElementById('error').style.display='none'">Réessayer</button>
        </div>

      </div>
    </section>

    <!-- CTA — texte modifié -->
    <section class="audit-cta">
      <div class="container">
        <h2>Besoin d'aide pour optimiser votre site ?</h2>
        <p>Notre équipe peut vous accompagner dans l'amélioration de vos performances SEO.</p>
        <a href="/#contact" class="cta-btn">On m'explique tout →</a>
      </div>
    </section>

    <!-- BOUTON RETOUR -->
    <section class="back-home-section">
      <div class="container">
        <a href="/" class="back-to-home">
          <span class="back-arrow">←</span>
          <span class="back-text">Retour à l'accueil</span>
        </a>
      </div>
    </section>

  </main>

  <Footer />
</Layout>

<style>
  :root {
    --orange: #ea6432;
    --black: #000000;
    --white: #ffffff;
    --gray: #9ca3af;
    --dark-card: #1a1a1a;
    --green: #10b981;
    --yellow: #f59e0b;
    --red: #ef4444;
  }

  .audit-page {
    background: var(--black);
    padding-top: 100px;
  }

  .container {
    max-width: var(--layout-width);
    margin: 0 auto;
    padding: 0 var(--gutter);
  }

  .audit-hero {
    padding: 80px 0 0 !important;
    text-align: left;
  }

  .hero-label {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--gray);
    margin-bottom: 16px;
  }

  .audit-hero h1 {
    font-size: 2.5rem;
    font-weight: 600;
    margin-bottom: 20px;
    color: var(--white);
  }

  .highlight { color: var(--orange); }

  .hero-subtitle {
    font-size: 1.1rem;
    color: var(--gray);
    max-width: 600px;
  }

  .audit-tool {
    padding: 80px 0 0 !important;
  }

  .audit-form-card {
    background: var(--dark-card);
    border: 2px solid #2a2a2a;
    border-radius: 16px;
    padding: 48px;
    margin-bottom: 40px;
  }

  .audit-form-card h2 {
    font-size: 1.5rem;
    color: var(--white);
    margin-bottom: 24px;
    text-align: center;
  }

  .input-group {
    display: flex;
    gap: 12px;
    max-width: 700px;
    margin: 0 auto;
  }

  #url-input {
    flex: 1;
    padding: 16px 24px;
    background: var(--black);
    border: 2px solid #2a2a2a;
    border-radius: 12px;
    color: var(--white);
    font-size: 1rem;
    transition: border-color 0.3s;
  }

  #url-input:focus {
    outline: none;
    border-color: var(--orange);
  }

  #analyze-btn {
    padding: 16px 48px;
    background: var(--orange);
    color: var(--white);
    border: none;
    border-radius: 12px;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s;
    white-space: nowrap;
  }

  #analyze-btn:hover {
    background: #d4581f;
    transform: translateY(-2px);
  }

  #analyze-btn:disabled {
    opacity: 0.6;
    cursor: not-allowed;
    transform: none;
  }

  .spinner {
    display: inline-block;
    width: 16px;
    height: 16px;
    border: 2px solid rgba(255,255,255,0.3);
    border-top-color: white;
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  .form-note {
    text-align: center;
    font-size: 0.85rem;
    color: var(--gray);
    margin-top: 12px;
    margin-bottom: 0;
  }

  .security-note {
    text-align: right;
    font-size: 0.78rem;
    color: var(--gray);
    margin-top: 10px;
    margin-bottom: 0;
    letter-spacing: 0.01em;
  }

  .result-card {
    background: var(--dark-card);
    border: 2px solid #2a2a2a;
    border-radius: 16px;
    padding: 32px;
    margin-bottom: 24px;
  }

  .result-card h3 {
    font-size: 1.3rem;
    color: var(--white);
    margin-bottom: 24px;
  }

  .score-card { text-align: center; }

  .score-circle {
    position: relative;
    width: 200px;
    height: 200px;
    margin: 0 auto 20px;
  }

  .score-circle svg { transform: rotate(-90deg); }

  .score-bg {
    fill: none;
    stroke: #2a2a2a;
    stroke-width: 12;
  }

  .score-fill {
    fill: none;
    stroke: var(--orange);
    stroke-width: 12;
    stroke-linecap: round;
    stroke-dasharray: 534;
    stroke-dashoffset: 534;
    transition: stroke-dashoffset 1s ease, stroke 0.5s;
  }

  .score-value {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-size: 3rem;
    font-weight: 700;
    color: var(--white);
  }

  .score-label {
    font-size: 1.1rem;
    color: var(--gray);
  }

  /* DIAGNOSTIC */
  .diagnostic-card {
    padding: 28px 32px;
    border-radius: 16px;
    border-width: 2px;
    border-style: solid;
  }

  .diagnostic-card.green {
    background: rgba(16, 185, 129, 0.07);
    border-color: rgba(16, 185, 129, 0.3);
  }

  .diagnostic-card.orange {
    background: rgba(245, 158, 11, 0.07);
    border-color: rgba(245, 158, 11, 0.3);
  }

  .diagnostic-card.red {
    background: rgba(239, 68, 68, 0.07);
    border-color: rgba(239, 68, 68, 0.3);
  }

  .diagnostic-header {
    font-size: 1.15rem;
    font-weight: 700;
    color: #ffffff !important;
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .diagnostic-items {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-bottom: 18px;
  }

  .diagnostic-item {
    font-size: 0.92rem;
    color: #ffffff !important;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  /* Force le blanc sur tous les spans enfants du diagnostic */
  .diagnostic-item span,
  .diagnostic-header span {
    color: #ffffff !important;
  }

  .diagnostic-cta {
    font-size: 0.9rem;
    color: var(--gray);
    padding-top: 14px;
    border-top: 1px solid #2a2a2a;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .vitals-grid { display: grid; gap: 20px; }

  .vital-item {
    display: grid;
    grid-template-columns: auto 1fr auto auto;
    gap: 16px;
    align-items: center;
    padding: 20px;
    background: var(--black);
    border-radius: 12px;
  }

  .vital-icon { font-size: 2rem; }

  .vital-info {
    display: flex;
    flex-direction: column;
  }

  .vital-label {
    font-size: 1rem;
    font-weight: 600;
    color: var(--white);
  }

  .vital-desc {
    font-size: 0.85rem;
    color: var(--gray);
  }

  .vital-value {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--white);
  }

  .vital-status {
    width: 12px;
    height: 12px;
    border-radius: 50%;
  }

  .vital-status.good { background: var(--green); }
  .vital-status.needs-improvement { background: var(--yellow); }
  .vital-status.poor { background: var(--red); }

  .meta-list { display: grid; gap: 16px; }

  .meta-item {
    display: grid;
    grid-template-columns: 120px 1fr auto;
    gap: 16px;
    align-items: start;
    padding: 16px;
    background: var(--black);
    border-radius: 8px;
  }

  .meta-label {
    font-weight: 600;
    color: var(--orange);
    font-size: 0.9rem;
  }

  .meta-value {
    color: var(--white);
    word-break: break-word;
  }

  .meta-length {
    font-size: 0.85rem;
    color: var(--gray);
    white-space: nowrap;
  }

  .meta-length.good { color: var(--green); }
  .meta-length.warning { color: var(--yellow); }

  .recommendations-list { display: grid; gap: 12px; }

  .recommendation-item {
    display: flex;
    gap: 12px;
    padding: 16px;
    background: var(--black);
    border-radius: 8px;
    border-left: 3px solid var(--orange);
  }

  .recommendation-icon {
    font-size: 1.2rem;
    flex-shrink: 0;
  }

  .recommendation-content {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .recommendation-text {
    color: #ffffff !important;
    line-height: 1.6;
    font-size: 0.95rem;
    margin: 0;
  }

  .recommendation-desc {
    font-size: 0.82rem;
    color: #9ca3af !important;
    line-height: 1.5;
    font-style: italic;
    margin: 0;
  }

  .error-card {
    background: rgba(239, 68, 68, 0.1);
    border: 2px solid var(--red);
    border-radius: 16px;
    padding: 48px;
    text-align: center;
  }

  .error-icon {
    font-size: 3rem;
    display: block;
    margin-bottom: 16px;
  }

  .error-card h3 { color: var(--white); margin-bottom: 12px; }
  .error-card p { color: var(--gray); margin-bottom: 24px; }

  .error-card button {
    padding: 12px 32px;
    background: var(--red);
    color: white;
    border: none;
    border-radius: 8px;
    cursor: pointer;
  }

  .audit-cta {
    padding: 80px 0;
    text-align: center;
  }

  .audit-cta h2 {
    font-size: 2rem;
    color: var(--white);
    margin-bottom: 16px;
  }

  .audit-cta p {
    font-size: 1.1rem;
    color: var(--gray);
    margin-bottom: 32px;
  }

  .cta-btn {
    display: inline-block;
    padding: 16px 48px;
    background: var(--orange);
    color: var(--white);
    text-decoration: none;
    border-radius: 999px;
    font-weight: 600;
    transition: all 0.3s;
  }

  .cta-btn:hover {
    background: #d4581f;
    transform: translateY(-2px);
  }

  .back-home-section {
    padding: 0 0 80px 0 !important;
    text-align: left;
  }

  .back-to-home {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--white);
    text-decoration: none;
    font-weight: 500;
    transition: gap 0.3s ease, color 0.3s ease;
  }

  .back-to-home:hover { gap: 0.75rem; color: var(--gray); }
  .back-arrow { transition: transform 0.3s ease; }
  .back-to-home:hover .back-arrow { transform: translateX(-3px); }

  @media (max-width: 768px) {
    .audit-hero h1 { font-size: 1.8rem; }
    .input-group { flex-direction: column; }
    .audit-form-card { padding: 32px 24px; }
    .result-card { padding: 24px; }

    .vital-item {
      grid-template-columns: auto 1fr;
      gap: 12px;
    }

    .vital-value,
    .vital-status {
      grid-column: 2;
      justify-self: end;
    }

    .meta-item {
      grid-template-columns: 1fr;
      gap: 8px;
    }

    .back-to-home { transition: none; }
    .back-to-home:hover { gap: 0.5rem; color: var(--white); }
    .back-to-home:hover .back-arrow { transform: none; }
    .security-note { text-align: center; }
  }
</style>

<script is:inline>
  var form = document.getElementById('audit-form');
  var urlInput = document.getElementById('url-input');
  var analyzeBtn = document.getElementById('analyze-btn');
  var btnText = analyzeBtn.querySelector('.btn-text');
  var btnLoader = analyzeBtn.querySelector('.btn-loader');
  var resultsDiv = document.getElementById('results');
  var errorDiv = document.getElementById('error');

  form.addEventListener('submit', async function(e) {
    e.preventDefault();

    var url = urlInput.value.trim();
    if (!url) return;

    analyzeBtn.disabled = true;
    btnText.style.display = 'none';
    btnLoader.style.display = 'flex';
    resultsDiv.style.display = 'none';
    errorDiv.style.display = 'none';

    try {
      var response = await fetch('/api/audit.json', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ url: url })
      });

      var data = await response.json();

      if (!response.ok || data.error) {
        throw new Error(data.error || "Impossible d'analyser cette URL");
      }

      displayResults(data);
      resultsDiv.style.display = 'block';
      document.getElementById('help-block').style.display = 'block';

    } catch (error) {
      console.error('Erreur:', error);
      document.getElementById('error-message').textContent = error.message;
      errorDiv.style.display = 'block';
    } finally {
      analyzeBtn.disabled = false;
      btnText.style.display = 'inline';
      btnLoader.style.display = 'none';
    }
  });

  function getSeverityIcon(score) {
    if (score >= 0.9) return '✅';
    if (score >= 0.5) return '⚠️';
    return '❌';
  }

  function displayResults(data) {
    var lighthouse = data.lighthouseResult;
    var categories = lighthouse.categories;
    var audits = lighthouse.audits;

    var perfScore = Math.round(categories.performance.score * 100);
    updateScore(perfScore);
    displayDiagnostic(perfScore);

    var lcp = audits['largest-contentful-paint'];
    var fid = audits['max-potential-fid'] || audits['total-blocking-time'];
    var cls = audits['cumulative-layout-shift'];

    updateVital('lcp', lcp.displayValue, lcp.score);
    updateVital('fid', fid.displayValue, fid.score);
    updateVital('cls', cls.displayValue, cls.score);

    var titleAudit = audits['document-title'];
    if (titleAudit) {
      var pageTitle = '';

      if (titleAudit.details && titleAudit.details.items && titleAudit.details.items.length > 0) {
        pageTitle = titleAudit.details.items[0].snippet || '';
      }

      if (!pageTitle && lighthouse.finalUrl) {
        try {
          var urlObj = new URL(lighthouse.finalUrl);
          pageTitle = urlObj.hostname;
        } catch (e) {
          pageTitle = lighthouse.finalUrl;
        }
      }

      if (pageTitle) {
        document.getElementById('meta-title').textContent = pageTitle;
        updateMetaLength('title', pageTitle.length);
      } else if (titleAudit.score === 1) {
        document.getElementById('meta-title').textContent = '✓ Présent';
      } else {
        document.getElementById('meta-title').textContent = '❌ Non trouvé';
      }
    }

    var metaDesc = audits['meta-description'];
    if (metaDesc) {
      if (metaDesc.score === 1) {
        document.getElementById('meta-description').textContent = '✓ Présente';
        document.getElementById('meta-description-length').textContent = '';
      } else {
        document.getElementById('meta-description').textContent = '❌ Manquante ou vide';
        document.getElementById('meta-description-length').textContent = '';
      }
    }

    document.getElementById('meta-og-image').textContent = 'Vérifier manuellement';

    var canonical = audits['canonical'];
    if (canonical && canonical.score === 1) {
      document.getElementById('meta-canonical').textContent = 'Présent ✓';
    } else {
      document.getElementById('meta-canonical').textContent = 'Non trouvé ❌';
    }

    displayRecommandations(audits);
  }

  function displayDiagnostic(score) {
    var card = document.getElementById('diagnostic-card');
    var header = document.getElementById('diagnostic-header');
    var items = document.getElementById('diagnostic-items');
    var cta = document.getElementById('diagnostic-cta');

    card.style.display = 'block';

    if (score >= 85) {
      card.className = 'result-card diagnostic-card green';
      header.innerHTML = '<span style="color:#ffffff">🟢 Votre site est performant 👍</span>';
      items.innerHTML = '<div class="diagnostic-item"><span>✔️</span><span style="color:#ffffff">Bonne vitesse</span></div><div class="diagnostic-item"><span>✔️</span><span style="color:#ffffff">Structure correcte</span></div><div class="diagnostic-item"><span>✔️</span><span style="color:#ffffff">Bon potentiel SEO</span></div>';
      cta.innerHTML = '👉 Vous pouvez encore optimiser certains points pour dépasser vos concurrents.';
    } else if (score >= 60) {
      card.className = 'result-card diagnostic-card orange';
      header.innerHTML = '<span style="color:#ffffff">🟠 Votre site fonctionne… mais perd des opportunités.</span>';
      items.innerHTML = '<div class="diagnostic-item"><span>⚠️</span><span style="color:#ffffff">Chargement perfectible</span></div><div class="diagnostic-item"><span>⚠️</span><span style="color:#ffffff">Quelques freins SEO</span></div><div class="diagnostic-item"><span>⚠️</span><span style="color:#ffffff">Risque de perte de trafic</span></div>';
      cta.innerHTML = '👉 Des optimisations simples peuvent améliorer votre visibilité.';
