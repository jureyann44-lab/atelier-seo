---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

const allPosts = await getCollection("blog");
const sortedPosts = allPosts.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
);
---

<Layout
  title="Blog Communication Digitale Le Mans | Conseils SEO & UX - Habeprod"
  description="Découvrez nos conseils en communication digitale : SEO, UX design, branding et stratégie web. Articles pratiques pour TPE et PME en Sarthe."
>
  <Nav />

  <section class="blog-page">
    <div class="container">
      <h1>Nos articles</h1>
      <p class="intro">
        Actualités, conseils et retours d'expérience en communication digitale
      </p>

      <div class="blog-grid">
        {
          sortedPosts.map((post) => (
            <article class="blog-card">
              <div class="blog-date">{post.data.date}</div>
              <h2>
                <a href={`/blog/${post.slug}`}>{post.data.title}</a>
              </h2>
              <p>{post.data.description}</p>
              <a href={`/blog/${post.slug}`} class="read-more">
                <span class="read-more-text">Lire l'article</span>
                <span class="read-more-arrow">→</span>
              </a>
            </article>
          ))
        }
      </div>

      <div class="blog-footer">
        <a href="/" class="back-to-home">
          <span class="back-arrow">←</span>
          <span class="back-text">Retour à l'accueil</span>
        </a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  .blog-page {
    background: #020308;
    min-height: 80vh;
    padding: 20rem 0 4rem;
  }

  .container {
    max-width: var(--layout-width);
    margin: 0 auto;
    width: 100%;
    padding: 0 var(--gutter);
  }

  h1 {
    font-size: 3rem;
    margin-bottom: 1rem;
    color: #ffffff;
  }

  .intro {
    font-size: 1.2rem;
    color: #d1d5db;
    margin-bottom: 4rem;
  }

  .blog-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
    gap: 2.5rem;
  }

  .blog-card {
    background: #0a0a0a;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 8px;
    padding: 0;
    transition: all 0.3s ease;
    overflow: hidden;
  }

  .blog-card:hover {
    border-color: rgba(255, 255, 255, 0.25);
    box-shadow: 0 8px 30px rgba(255, 255, 255, 0.08);
    transform: translateY(-4px);
  }

  .blog-date {
    font-size: 0.85rem;
    text-transform: uppercase;
    color: #9ca3af;
    margin-bottom: 1rem;
    letter-spacing: 0.1em;
    padding: 2rem 2rem 0;
  }

  .blog-card h2 {
    font-size: 1.5rem;
    margin-bottom: 1rem;
    padding: 0 2rem;
  }

  .blog-card h2 a {
    color: #ffffff;
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .blog-card h2 a:hover {
    color: #9ca3af;
  }

  .blog-card p {
    color: #d1d5db;
    line-height: 1.7;
    margin-bottom: 1.5rem;
    padding: 0 2rem;
  }

  .read-more {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: #ffffff;
    text-decoration: none;
    font-weight: 500;
    text-transform: uppercase;
    font-size: 0.9rem;
    letter-spacing: 0.05em;
    transition: gap 0.3s ease;
    padding: 0 2rem 2rem;
  }

  .read-more:hover {
    gap: 0.75rem;
  }

  .read-more-arrow {
    transition: transform 0.3s ease;
  }

  .read-more:hover .read-more-arrow {
    transform: translateX(3px);
  }

  .blog-footer {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.15);
  }

  .back-to-home {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: #ffffff;
    text-decoration: none;
    font-weight: 500;
    transition:
      gap 0.3s ease,
      color 0.3s ease;
  }

  .back-to-home:hover {
    gap: 0.75rem;
    color: #9ca3af;
  }

  .back-arrow {
    transition: transform 0.3s ease;
  }

  .back-to-home:hover .back-arrow {
    transform: translateX(-3px);
  }

  /* 🔥 MOBILE (tactile OU petit écran) */
  @media (max-width: 900px), (max-width: 1023px) and (pointer: coarse) {
    .blog-page {
      padding: 10rem 0 4rem;
    }

    .blog-grid {
      grid-template-columns: 1fr;
    }

    .blog-card:hover {
      transform: none;
    }

    .read-more {
      transition: none;
    }

    .read-more:hover {
      gap: 0.5rem;
    }

    .read-more:hover .read-more-arrow {
      transform: none;
    }

    .back-to-home {
      transition: none;
    }

    .back-to-home:hover {
      gap: 0.5rem;
      color: #ffffff;
    }

    .back-to-home:hover .back-arrow {
      transform: none;
    }
  }
</style>
