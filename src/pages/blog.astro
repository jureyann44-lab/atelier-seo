---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

const allPosts = await getCollection("blog");
const sortedPosts = allPosts.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
);

function formatDate(dateString: string): string {
  const date = new Date(dateString);
  const day = date.getDate();
  const months = [
    "janvier", "février", "mars", "avril", "mai", "juin",
    "juillet", "août", "septembre", "octobre", "novembre", "décembre",
  ];
  const month = months[date.getMonth()];
  const year = date.getFullYear();
  return `${day} ${month} ${year}`;
}
---

<Layout
  title="Blog SEO Le Mans | Conseils Référencement Naturel & SEO Local - SEO Atelier"
  description="Conseils SEO, référencement local, stratégie de contenu et GEO : les ressources de SEO Atelier pour améliorer votre visibilité sur Google au Mans et en Sarthe."
  canonical="https://atelier-seo.fr/blog/"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Blog",
      "name": "Blog SEO Atelier",
      "description": "Conseils SEO, référencement local, stratégie de contenu et GEO pour les entreprises du Mans et de la Sarthe.",
      "url": "https://atelier-seo.fr/blog/",
      "publisher": {
        "@type": "LocalBusiness",
        "name": "SEO Atelier",
        "url": "https://atelier-seo.fr",
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "Le Mans",
          "addressRegion": "Sarthe",
          "addressCountry": "FR"
        },
        "logo": {
          "@type": "ImageObject",
          "url": "https://atelier-seo.fr/logo-seo-atelier.png"
        }
      }
    })} />
  </Fragment>

  <Nav />

  <section class="blog-page">
    <div class="container">
      <h1>Nos ressources SEO</h1>
      <p class="intro">
        Conseils, méthodes et retours terrain pour améliorer votre référencement au Mans et en Sarthe
      </p>

      <div class="blog-grid">
        {
          sortedPosts.map((post) => (
            <article class="blog-card">
              {post.data.image && (
                <a href={`/blog/${post.slug}`} class="blog-card-image-link">
                  <Image
                    src={post.data.image}
                    alt={post.data.title}
                    width={800}
                    height={450}
                    class="blog-card-image"
                    loading="lazy"
                  />
                </a>
              )}
              <div class="blog-card-content">
                <div class="blog-card-meta">
                  <span class="blog-date">{formatDate(post.data.date)}</span>
                  {post.data.tags && post.data.tags.length > 0 && (
                    <div class="blog-tags">
                      {post.data.tags.slice(0, 2).map((tag: string) => (
                        <span class="blog-tag">{tag}</span>
                      ))}
                    </div>
                  )}
                </div>
                <h2>
                  <a href={`/blog/${post.slug}`}>{post.data.title}</a>
                </h2>
                <p>{post.data.description}</p>
                <a href={`/blog/${post.slug}`} class="read-more">
                  <span class="read-more-text">Lire l'article</span>
                  <span class="read-more-arrow">→</span>
                </a>
              </div>
            </article>
          ))
        }
      </div>

      <div class="blog-footer">
        <a href="/" class="back-to-home">
          <span class="back-arrow">←</span>
          <span class="back-text">Retour à l'accueil</span>
        </a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  .blog-page {
    background: #020308;
    min-height: 80vh;
    padding: 20rem 0 4rem;
  }

  .container {
    max-width: var(--layout-width);
    margin: 0 auto;
    width: 100%;
    padding: 0 var(--gutter);
  }

  h1 {
    font-size: 3rem;
    margin-bottom: 1rem;
    color: #ffffff;
  }

  .intro {
    font-size: 1.2rem;
    color: #d1d5db;
    margin-bottom: 4rem;
  }

  .blog-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
    gap: 2.5rem;
  }

  .blog-card {
    background: #0a0a0a;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 8px;
    overflow: hidden;
    transition: all 0.3s ease;
    display: flex;
    flex-direction: column;
  }

  .blog-card:hover {
    border-color: rgba(255, 255, 255, 0.25);
    box-shadow: 0 8px 30px rgba(255, 255, 255, 0.08);
    transform: translateY(-4px);
  }

  .blog-card-image-link {
    display: block;
    overflow: hidden;
  }

  .blog-card-image {
    width: 100%;
    height: 200px;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .blog-card:hover .blog-card-image {
    transform: scale(1.03);
  }

  .blog-card-content {
    padding: 2rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .blog-card-meta {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    margin-bottom: 1rem;
    gap: 0.6rem;
  }

  .blog-date {
    font-size: 0.85rem;
    text-transform: uppercase;
    color: #9ca3af;
    letter-spacing: 0.1em;
  }

  .blog-tags {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .blog-tag {
    font-size: 0.75rem;
    color: #9ca3af;
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 4px;
    padding: 0.2rem 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .blog-card h2 {
    font-size: 1.3rem;
    margin-bottom: 1rem;
  }

  .blog-card h2 a {
    color: #ffffff;
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .blog-card h2 a:hover {
    color: #9ca3af;
  }

  .blog-card p {
    color: #d1d5db;
    line-height: 1.7;
    margin-bottom: 1.5rem;
    flex: 1;
  }

  .read-more {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: #ffffff;
    text-decoration: none;
    font-weight: 500;
    text-transform: uppercase;
    font-size: 0.9rem;
    letter-spacing: 0.05em;
    transition: gap 0.3s ease;
    margin-top: auto;
  }

  .read-more:hover {
    gap: 0.75rem;
  }

  .read-more-arrow {
    transition: transform 0.3s ease;
  }

  .read-more:hover .read-more-arrow {
    transform: translateX(3px);
  }

  .blog-footer {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.15);
  }

  .back-to-home {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: #ffffff;
    text-decoration: none;
    font-weight: 500;
    transition: gap 0.3s ease, color 0.3s ease;
  }

  .back-to-home:hover {
    gap: 0.75rem;
    color: #9ca3af;
  }

  .back-arrow {
    transition: transform 0.3s ease;
  }

  .back-to-home:hover .back-arrow {
    transform: translateX(-3px);
  }

  /* 📱 MOBILE LANDSCAPE */
  @media (min-width: 667px) and (max-width: 960px) and (orientation: landscape) and (max-height: 450px) {
    .blog-page {
      padding: calc(var(--nav-height) + 3rem) 0 3rem !important;
    }

    h1 {
      font-size: 2rem;
      margin-bottom: 0.75rem;
    }

    .intro {
      font-size: 1rem;
      margin-bottom: 2rem;
    }

    .blog-grid {
      gap: 2rem;
    }
  }

  /* 📱 iPad Mini PORTRAIT */
  @media (min-width: 768px) and (max-width: 820px) and (orientation: portrait) {
    .container {
      max-width: 90% !important;
      margin: 0 auto !important;
    }
  }

  /* 🔥 MOBILE */
  @media (max-width: 900px), (max-width: 1023px) and (pointer: coarse) {
    .blog-page {
      padding: 10rem 0 4rem;
    }

    .blog-grid {
      grid-template-columns: 1fr;
    }

    .blog-card:hover {
      transform: none;
    }

    .blog-card:hover .blog-card-image {
      transform: none;
    }

    .read-more {
      transition: none;
    }

    .read-more:hover {
      gap: 0.5rem;
    }

    .read-more:hover .read-more-arrow {
      transform: none;
    }

    .back-to-home {
      transition: none;
    }

    .back-to-home:hover {
      gap: 0.5rem;
      color: #ffffff;
    }

    .back-to-home:hover .back-arrow {
      transform: none;
    }
  }
</style>