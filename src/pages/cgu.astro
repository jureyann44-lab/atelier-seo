---
import LegalLayout from "../layouts/LegalLayout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
---

<LegalLayout
  title="CGU | Habeprod - Agence Web au Mans"
  description="Conditions Générales d'Utilisation de l'agence Habeprod."
  canonical="https://www.habeprod-agence.fr/cgu"
>
  <Nav />

  <main class="mentions-legales">
    <div class="container">
      <h1>Conditions Générales d'Utilisation (CGU)</h1>

      <!-- Tout votre contenu CGU existant -->
      <section class="legal-section">
        <h2>Objet</h2>
        <p>
          Les présentes Conditions Générales d'Utilisation (CGU) ont pour objet
          de définir les modalités de mise à disposition des services du site <strong
            >Habeprod</strong
          > et les conditions d'utilisation par l'Utilisateur.
        </p>
      </section>

      <!-- ... reste du contenu ... -->

      <p class="last-update">Dernière mise à jour : 21 décembre 2025</p>
    </div>
  </main>

  <Footer />
</LegalLayout>

<style>
  .mentions-legales {
    background: #000;
    color: #fff;
    min-height: 100vh;
    padding-top: calc(var(--nav-height) + 4rem);
    padding-bottom: 4rem;
  }

  .mentions-legales section {
    padding: 0 !important;
  }

  .mentions-legales h1 {
    font-size: 3rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    margin-bottom: 3rem;
  }

  .legal-section {
    margin-bottom: 3rem;
  }

  .mentions-legales h2 {
    font-size: 1.5rem !important;
    font-weight: 500 !important;
    margin-bottom: 1.5rem !important;
    color: #fff;
    letter-spacing: -0.01em !important;
  }

  .mentions-legales p {
    font-size: 1rem;
    line-height: 1.8;
    margin-bottom: 1rem;
    color: rgba(255, 255, 255, 0.85);
  }

  .mentions-legales strong {
    color: #fff;
    font-weight: 600;
  }

  .legal-link {
    color: #eb6432;
    text-decoration: none;
    transition: opacity var(--transition-speed);
  }

  .legal-link:hover {
    opacity: 0.8;
    text-decoration: underline;
  }

  .last-update {
    margin-top: 4rem;
    text-align: center;
    font-size: 0.9rem;
    opacity: 0.6;
    font-style: italic;
  }

  @media (max-width: 900px) {
    .mentions-legales {
      padding-top: calc(var(--nav-height) + 2rem);
      padding-bottom: 2rem;
    }

    .mentions-legales h1 {
      font-size: 2rem;
      margin-bottom: 2rem;
    }

    .mentions-legales h2 {
      font-size: 1.25rem !important;
    }

    .legal-section {
      margin-bottom: 2rem;
    }
  }
</style>
