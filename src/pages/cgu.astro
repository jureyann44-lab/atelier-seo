<style>
  .mentions-legales {
    background: #000;
    color: #fff;
    min-height: 100vh;
    padding-top: calc(var(--nav-height) + 4rem);
    padding-bottom: 4rem;
  }

  .mentions-legales section {
    padding: 0 !important;
  }

  .mentions-legales h1 {
    font-size: 3rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    margin-bottom: 3rem;
  }

  .legal-section {
    margin-bottom: 3rem;
  }

  .mentions-legales h2 {
    font-size: 1.5rem !important;
    font-weight: 500 !important;
    margin-bottom: 1.5rem !important;
    color: #fff;
    letter-spacing: -0.01em !important;
  }

  .mentions-legales p {
    font-size: 1rem;
    line-height: 1.8;
    margin-bottom: 1rem;
    color: rgba(255, 255, 255, 0.85);
  }

  .mentions-legales strong {
    color: #fff;
    font-weight: 600;
  }

  .legal-link {
    color: rgba(255, 255, 255, 0.6);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color var(--transition-speed);
  }

  .legal-link:hover {
    color: #ffffff;
  }

  .last-update {
    margin-top: 4rem;
    text-align: center;
    font-size: 0.9rem;
    opacity: 0.6;
    font-style: italic;
  }

  /* 📱 MOBILE LANDSCAPE */
  @media (min-width: 667px) and (max-width: 960px) and (orientation: landscape) and (max-height: 450px) {
    .mentions-legales {
      padding-top: calc(var(--nav-height) + 2rem);
      padding-bottom: 2rem;
    }

    .mentions-legales h1 {
      font-size: 2rem;
      margin-bottom: 1.5rem;
    }

    .mentions-legales h2 {
      font-size: 1.25rem !important;
      margin-bottom: 1rem !important;
    }

    .legal-section {
      margin-bottom: 2rem;
    }

    .mentions-legales p {
      font-size: 0.95rem;
    }
  }

  /* 📱 iPad Mini PORTRAIT */
  @media (min-width: 768px) and (max-width: 820px) and (orientation: portrait) {
    .container {
      max-width: 90% !important;
      margin: 0 auto !important;
    }
  }

  /* 🔥 MOBILE */
  @media (max-width: 900px), (max-width: 1023px) and (pointer: coarse) {
    .mentions-legales {
      padding-top: calc(var(--nav-height) + 2rem);
      padding-bottom: 2rem;
    }

    .mentions-legales h1 {
      font-size: 2rem;
      margin-bottom: 2rem;
    }

    .mentions-legales h2 {
      font-size: 1.25rem !important;
    }

    .legal-section {
      margin-bottom: 2rem;
    }
  }
</style>

<script>
  document.querySelectorAll('a[href^="#"]').forEach((anchor) => {
    anchor.addEventListener("click", (e) => {
      const href = anchor.getAttribute("href");
      if (!href || href === "#") return;

      const target = document.querySelector(href);
      if (!target) return;

      e.preventDefault();
      target.scrollIntoView({ behavior: "smooth", block: "start" });
    });
  });
</script>