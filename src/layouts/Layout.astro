---
const {
  title = "Agence de communication au Mans | SEO & Sites performants | Habeprod",
  description = "Agence de communication au Mans pour TPE et PME en Sarthe. Sites performants, SEO local, stratégie digitale. 10 ans d'expérience. Devis gratuit.",
  canonical = "https://www.habeprod-agence.fr/",
  ogImage = "https://cdn.prod.website-files.com/681b6b36dcb0f115f4d39f76/681c83218f79910e7d6aff03_image-hero.webp",
  faq = null,
} = Astro.props;
---

<!doctype html>
<html lang="fr">
  <head>
    <!-- META SEO -->
    <title>{title}</title>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/favicon.ico" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- OPEN GRAPH -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Habeprod" />
    <meta property="og:locale" content="fr_FR" />

    <!-- TWITTER CARD -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- FONTS -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />

    <!-- SCHEMA LOCAL BUSINESS -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@graph": [
          {
            "@type": "MarketingAgency",
            "@id": canonical + "#localbusiness",
            name: "Habeprod",
            legalName: "Habeprod",
            description: description,
            url: canonical,
            logo: canonical + "logo-habeprod.png",
            image: canonical + "logo-habeprod.png",
            foundingDate: "2018",
            priceRange: "$$",
            telephone: "+33627252568",
            address: {
              "@type": "PostalAddress",
              streetAddress: "35 rue d'Iena",
              postalCode: "72000",
              addressLocality: "Le Mans",
              addressCountry: "FR",
            },
            geo: {
              "@type": "GeoCoordinates",
              latitude: 48.003386,
              longitude: 0.199563,
            },
            openingHoursSpecification: [
              {
                "@type": "OpeningHoursSpecification",
                dayOfWeek: [
                  "Monday",
                  "Tuesday",
                  "Wednesday",
                  "Thursday",
                  "Friday",
                ],
                opens: "09:00",
                closes: "18:00",
              },
            ],
            sameAs: [
              "https://www.facebook.com/habeprod",
              "https://www.instagram.com/habeprod",
              "https://www.linkedin.com/company/habeprod",
              "https://discord.gg/gna3b2YNUq",
            ],
          },
        ],
      })}
    />
  </head>

  <body>
    <slot />

    <!-- ✅ SÉCURITÉ LIENS EXTERNES -->
    <script>
      document.addEventListener("DOMContentLoaded", function () {
        document.querySelectorAll('a[target="_blank"]').forEach((link) => {
          link.setAttribute("rel", "noopener noreferrer");
        });
      });
    </script>
  </body>
</html>

<style is:global>
  @import "../styles/global.css";
</style>
