---
// Props explicites, non optionnelles pour éviter les erreurs
interface Props {
  title: string;
  description: string;
  canonical: string;
}

// On récupère Astro.props avec fallback
const props: Props = {
  title:
    Astro.props.title ||
    "Agence Web & SEO au Mans – Sites performants | Habeprod",
  description:
    Astro.props.description ||
    "Agence web au Mans spécialisée en création de sites performants, SEO local et stratégie digitale.",
  canonical: Astro.props.canonical || "https://www.habeprod-agence.fr/",
};

const { title, description, canonical } = props;

const ogImage =
  "https://cdn.prod.website-files.com/681b6b36dcb0f115f4d39f76/681c83218f79910e7d6aff03_image-hero.webp";
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="canonical" href={canonical} />

    <!-- OPEN GRAPH -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Habeprod" />
    <meta property="og:locale" content="fr_FR" />

    <!-- TWITTER CARD -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- FONTS -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>

  <body>
    <slot />

    <script>
      document.addEventListener("DOMContentLoaded", () => {
        document.querySelectorAll('a[target="_blank"]').forEach((link) => {
          link.setAttribute("rel", "noopener noreferrer");
        });
      });
    </script>
  </body>
</html>

<style is:global>
  @import "../styles/global.css";
</style>
