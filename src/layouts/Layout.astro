---
import StickyMobileBar from '../components/StickyMobileBar.astro';
import CookieBanner from '../components/CookieBanner.astro';
const {
  title = "Consultant SEO au Mans – Référencement Google & SEO local | L'Atelier SEO",
  description = "Consultant SEO au Mans spécialisé en référencement Google et SEO local pour les entreprises de la Sarthe. Audit SEO gratuit et stratégie de visibilité durable.",
  canonical = "https://atelier-seo.fr/",
  ogImage = "https://atelier-seo.fr/atelier-seo-logo-dark.png",
  ogTitle = title,
  ogDescription = description,
  faq = null,
  robots = "index, follow",
} = Astro.props;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="robots" content={robots} />
    <meta name="google-site-verification" content="BqGuGC7TSIuxEzf4sCnyRbwv3B_7f0RkHrLsNIsmyrs" />
    <meta name="author" content="L'Atelier SEO" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="theme-color" content="#0a0a0a" />

    <!-- GÉOLOCALISATION -->
    <meta name="geo.region" content="FR-72" />
    <meta name="geo.placename" content="Le Mans" />
    <meta name="geo.position" content="48.003386;0.199563" />
    <meta name="ICBM" content="48.003386, 0.199563" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="L'Atelier SEO" />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="L'Atelier SEO – Consultant SEO au Mans" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={ogDescription} />
    <meta name="twitter:image" content={ogImage} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&family=Montserrat:wght@300;400;500;600&display=swap" rel="stylesheet" />

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "WebSite",
          "@id": "https://atelier-seo.fr/#website",
          url: "https://atelier-seo.fr",
          name: "L'Atelier SEO",
          publisher: { "@id": "https://atelier-seo.fr/#localbusiness" },
          creator: { "@id": "https://atelier-seo.fr/#person" },
        },
        {
          "@type": "WebPage",
          "@id": "https://atelier-seo.fr/#webpage",
          url: "https://atelier-seo.fr",
          name: title,
          description: description,
          inLanguage: "fr",
          isPartOf: { "@id": "https://atelier-seo.fr/#website" },
        },
        {
          "@type": ["Organization", "LocalBusiness", "ProfessionalService"],
          "@id": "https://atelier-seo.fr/#localbusiness",
          name: "L'Atelier SEO",
          legalName: "L'Atelier SEO",
          description: description,
          url: "https://atelier-seo.fr",
          logo: {
            "@type": "ImageObject",
            url: "https://atelier-seo.fr/logo-atelier-seo.png",
            width: 1024,
            height: 1024,
          },
          image: "https://atelier-seo.fr/atelier-seo-logo-dark.png",
          foundingDate: "2024",
          priceRange: "$$",
          telephone: "+33627252568",
          email: "contact@atelier-seo.fr",
          address: {
            "@type": "PostalAddress",
            streetAddress: "35 rue d'Iéna",
            postalCode: "72000",
            addressLocality: "Le Mans",
            addressRegion: "Sarthe",
            addressCountry: "FR",
          },
          geo: {
            "@type": "GeoCoordinates",
            latitude: 48.003386,
            longitude: 0.199563,
          },
          areaServed: [
            { "@type": "City", name: "Le Mans" },
            { "@type": "AdministrativeArea", name: "Sarthe" },
            { "@type": "City", name: "Angers" },
            { "@type": "City", name: "Nantes" },
            { "@type": "AdministrativeArea", name: "Pays de la Loire" },
          ],
          serviceArea: { "@type": "AdministrativeArea", name: "Sarthe" },
          makesOffer: [
            {
              "@type": "Offer",
              itemOffered: {
                "@type": "Service",
                name: "Audit SEO",
                description: "Analyse complète du site pour identifier les axes d'amélioration et les opportunités de référencement au Mans et en Sarthe.",
              },
            },
            {
              "@type": "Offer",
              itemOffered: {
                "@type": "Service",
                name: "Référencement naturel",
                description: "Optimisation du référencement naturel pour améliorer durablement la visibilité sur Google.",
              },
            },
            {
              "@type": "Offer",
              itemOffered: {
                "@type": "Service",
                name: "SEO local",
                description: "Stratégie de référencement local pour apparaître sur Google Maps et les recherches géolocalisées au Mans.",
              },
            },
            {
              "@type": "Offer",
              itemOffered: {
                "@type": "Service",
                name: "Stratégie SEO",
                description: "Élaboration d'une stratégie SEO sur mesure adaptée aux objectifs des entreprises de la Sarthe et des Pays de la Loire.",
              },
            },
            {
              "@type": "Offer",
              itemOffered: {
                "@type": "Service",
                name: "Optimisation technique SEO",
                description: "Optimisation des performances techniques du site : vitesse, structure, Core Web Vitals et accessibilité pour les moteurs de recherche.",
              },
            },
            {
              "@type": "Offer",
              itemOffered: {
                "@type": "Service",
                name: "Rédaction SEO",
                description: "Création de contenus optimisés pour le référencement naturel, ciblant les requêtes locales au Mans et en Sarthe.",
              },
            },
          ],
          knowsAbout: [
            "SEO local", "SEO Le Mans", "référencement Google",
            "référencement Le Mans", "consultant SEO Le Mans",
            "consultant SEO Sarthe", "SEO Sarthe", "audit SEO",
            "stratégie de contenu SEO",
          ],
          contactPoint: {
            "@type": "ContactPoint",
            telephone: "+33627252568",
            contactType: "customer service",
            areaServed: "FR",
            availableLanguage: "French",
          },
          openingHoursSpecification: [
            {
              "@type": "OpeningHoursSpecification",
              dayOfWeek: ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
              opens: "09:00",
              closes: "18:00",
            },
          ],
          hasMap: "https://www.google.com/maps",
          sameAs: [
            "https://www.habeprod-agence.fr",
            "https://www.linkedin.com/company/95178904/",
            "https://share.google/VnBgZH20kpBOdHCcw",
          ],
        },
        {
          "@type": "Person",
          "@id": "https://atelier-seo.fr/#person",
          name: "Yann",
          jobTitle: "Consultant SEO",
          worksFor: { "@id": "https://atelier-seo.fr/#localbusiness" },
          memberOf: { "@id": "https://atelier-seo.fr/#localbusiness" },
          url: "https://atelier-seo.fr",
          sameAs: [
            "https://www.habeprod-agence.fr",
            "https://www.linkedin.com/company/95178904/",
            "https://share.google/VnBgZH20kpBOdHCcw",
          ],
        },
        {
          "@type": "BreadcrumbList",
          "@id": "https://atelier-seo.fr/#breadcrumb",
          itemListElement: [
            {
              "@type": "ListItem",
              position: 1,
              name: "Accueil",
              item: "https://atelier-seo.fr",
            },
          ],
        },
      ],
    })} />

    {faq && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "FAQPage",
        mainEntity: faq.map((item: { question: string; answer: string }) => ({
          "@type": "Question",
          name: item.question,
          acceptedAnswer: { "@type": "Answer", text: item.answer },
        })),
      })} />
    )}
    <slot name="head" />
  </head>

  <body>
    <slot />

    <StickyMobileBar />
    <CookieBanner />

    <script>
      document.addEventListener("DOMContentLoaded", function () {
        document.querySelectorAll('a[target="_blank"]').forEach((link) => {
          link.setAttribute("rel", "noopener noreferrer");
        });
      });
    </script>
  </body>
</html>

<style is:global>
  @import "../styles/global.css";
</style>