---
const {
  title,
  description,
  canonical = "https://www.habeprod-agence.fr/",
} = Astro.props;

import CookieBanner from "../components/CookieBanner.astro";

const ogImage =
  "https://cdn.prod.website-files.com/681b6b36dcb0f115f4d39f76/681c83218f79910e7d6aff03_image-hero.webp";
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />

    <!-- OPEN GRAPH -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Habeprod" />
    <meta property="og:locale" content="fr_FR" />

    <!-- TWITTER CARD -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- SCHEMA LOCAL BUSINESS -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": ["LocalBusiness", "ProfessionalService"],
        "@id": canonical + "#localbusiness",
        name: "Habeprod",
        legalName: "Habeprod",
        description: description,
        url: canonical,
        logo: ogImage,
        image: ogImage,
        priceRange: "$$",
        telephone: "+33627252568",
        email: "agence.habeprod@gmail.com",

        // Coordonnées géographiques
        geo: {
          "@type": "GeoCoordinates",
          latitude: "47.998543990775",
          longitude: "0.194459986032",
        },

        // Adresse complète
        address: {
          "@type": "PostalAddress",
          streetAddress: "35 rue d'Iéna",
          addressLocality: "Le Mans",
          addressRegion: "Pays de la Loire",
          postalCode: "72000",
          addressCountry: "FR",
        },

        // Zone de service
        areaServed: [
          {
            "@type": "City",
            name: "Le Mans",
          },
          {
            "@type": "AdministrativeArea",
            name: "Sarthe",
          },
          {
            "@type": "State",
            name: "Pays de la Loire",
          },
        ],

        // Horaires d'ouverture
        openingHoursSpecification: [
          {
            "@type": "OpeningHoursSpecification",
            dayOfWeek: ["Monday", "Tuesday", "Wednesday"],
            opens: "09:00",
            closes: "18:00",
          },
          {
            "@type": "OpeningHoursSpecification",
            dayOfWeek: "Thursday",
            opens: "09:00",
            closes: "17:00",
          },
          {
            "@type": "OpeningHoursSpecification",
            dayOfWeek: "Friday",
            opens: "09:00",
            closes: "18:00",
          },
        ],

        // Services offerts
        hasOfferCatalog: {
          "@type": "OfferCatalog",
          name: "Services digitaux",
          itemListElement: [
            {
              "@type": "Offer",
              itemOffered: {
                "@type": "Service",
                name: "Création site internet Le Mans",
                areaServed: "Le Mans",
              },
            },
            {
              "@type": "Offer",
              itemOffered: {
                "@type": "Service",
                name: "Agence SEO Le Mans",
                areaServed: "Le Mans",
              },
            },
            {
              "@type": "Offer",
              itemOffered: {
                "@type": "Service",
                name: "Stratégie digitale Sarthe",
                areaServed: "Sarthe",
              },
            },
          ],
        },

        sameAs: [
          "https://www.instagram.com/habeprod",
          "https://www.linkedin.com/company/habeprod",
        ],
      })}
    />
    <!-- FONTS -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>

  <body>
    <slot />
    <CookieBanner />

    <script>
      document.addEventListener("DOMContentLoaded", () => {
        document.querySelectorAll('a[target="_blank"]').forEach((link) => {
          link.setAttribute("rel", "noopener noreferrer");
        });
      });
    </script>
  </body>
</html>

<style is:global>
  @import "../styles/global.css";
</style>
