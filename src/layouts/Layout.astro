---
import CookieBanner from "../components/CookieBanner.astro";

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>

    <!-- ✅ BALISES OPEN GRAPH -->
    <meta
      property="og:title"
      content="Habeprod – Agence de communication au Mans"
    />
    <meta
      property="og:description"
      content="Conçois un site web qui performe, booste ton SEO et déploie ta visibilité grâce à Habeprod, agence de communication au Mans."
    />
    <meta
      property="og:image"
      content="https://cdn.prod.website-files.com/681b6b36dcb0f115f4d39f76/681c83218f79910e7d6aff03_image-hero.webp"
    />
    <meta property="og:url" content="https://www.habeprod-agence.fr/" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Habeprod" />
    <meta property="og:locale" content="fr_FR" />

    <!-- ✅ TWITTER CARD -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta
      name="twitter:title"
      content="Habeprod – Agence de communication au Mans"
    />
    <meta
      name="twitter:description"
      content="Conçois un site web qui performe, booste ton SEO, et fais décoller ta stratégie digitale au Mans et en France."
    />
    <meta
      name="twitter:image"
      content="https://cdn.prod.website-files.com/681b6b36dcb0f115f4d39f76/681c83218f79910e7d6aff03_image-hero.webp"
    />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />

    <!-- ✅ STYLE ANTI-OVERSCROLL + ANTI-HORIZONTAL -->
    <style>
      html {
        overflow-x: hidden;
        overscroll-behavior: none;
      }

      body {
        overflow-x: hidden;
        overscroll-behavior: none;
        touch-action: pan-y;
        position: relative;
        width: 100%;
      }

      .visually-hidden {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
      }
    </style>

    <!-- ✅ DONNÉES STRUCTURÉES SCHEMA.ORG -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "LocalBusiness",
        "@id": "https://habeprod-agence.fr/#localbusiness",
        "name": "Habeprod – Agence de communication au Mans",
        "legalName": "HabeProd",
        "description": "Agence spécialisée en communication visuelle, digitale, print et création de site web au Mans",
        "url": "https://habeprod-agence.fr/",
        "logo": "https://cdn.prod.website-files.com/681b6b36dcb0f115f4d39f76/681c8bff61b0c16e5eae49aa_logo-version-2.webp",
        "image": "https://cdn.prod.website-files.com/681b6b36dcb0f115f4d39f76/681c8bff61b0c16e5eae49aa_logo-version-2.webp",
        "foundingDate": "2018",
        "priceRange": "$$",
        "telephone": "+33627252568",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "35 rue d'Iena",
          "postalCode": "72000",
          "addressLocality": "Le Mans",
          "addressCountry": "FR"
        },
        "geo": {
          "@type": "GeoCoordinates",
          "latitude": 48.003386,
          "longitude": 0.199563
        },
        "openingHoursSpecification": [
          {
            "@type": "OpeningHoursSpecification",
            "dayOfWeek": [
              "Monday",
              "Tuesday",
              "Wednesday",
              "Thursday",
              "Friday"
            ],
            "opens": "09:00",
            "closes": "18:00"
          }
        ],
        "sameAs": [
          "https://www.facebook.com/habeprod",
          "https://www.instagram.com/habeprod",
          "https://www.linkedin.com/company/habeprod",
          "https://discord.gg/gna3b2YNUq"
        ]
      }
    </script>
  </head>
  <body>
    <slot />

    <!-- ✅ Bandeau cookies RGPD -->
    <CookieBanner />

    <!-- ✅ SÉCURITÉ LIENS EXTERNES -->
    <script>
      document.addEventListener("DOMContentLoaded", function () {
        document.querySelectorAll('a[target="_blank"]').forEach((link) => {
          link.setAttribute("rel", "noopener noreferrer");
        });
      });
    </script>
  </body>
</html>
