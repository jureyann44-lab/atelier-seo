---
const {
  title = "Agence Web & SEO au Mans – Sites performants | Habeprod",
  description = "Agence web au Mans spécialisée en création de sites performants, SEO local et stratégie digitale. Plus de 10 ans d'expérience. Devis gratuit.",
  canonical = "https://www.habeprod-agence.fr/",
  ogImage = "https://cdn.prod.website-files.com/681b6b36dcb0f115f4d39f76/681c83218f79910e7d6aff03_image-hero.webp",
  faq = null,
} = Astro.props;
---

<!doctype html>
<html lang="fr">
  <head>
    <!-- META SEO -->
    <title>{title}</title>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- OPEN GRAPH -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Habeprod" />
    <meta property="og:locale" content="fr_FR" />

    <!-- TWITTER CARD -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- FONTS -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />

    <!-- STYLE ANTI-OVERSCROLL + ANTI-HORIZONTAL -->
    <style>
      html {
        overflow-x: hidden;
        overscroll-behavior: none;
      }
      body {
        overflow-x: hidden;
        overscroll-behavior: none;
        touch-action: pan-y;
        position: relative;
        width: 100%;
      }
      .visually-hidden {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
      }
    </style>

    <!-- SCHEMA LOCAL BUSINESS (SANS FAQ) -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@graph": [
          {
            "@type": ["LocalBusiness", "ProfessionalService"],
            "@id": canonical + "#localbusiness",
            name: "Habeprod",
            legalName: "Habeprod",
            description: description,
            url: canonical,
            logo: ogImage,
            image: ogImage,
            foundingDate: "2018",
            priceRange: "$$",
            telephone: "+33627252568",
            address: {
              "@type": "PostalAddress",
              streetAddress: "35 rue d'Iena",
              postalCode: "72000",
              addressLocality: "Le Mans",
              addressCountry: "FR",
            },
            geo: {
              "@type": "GeoCoordinates",
              latitude: 48.003386,
              longitude: 0.199563,
            },
            openingHoursSpecification: [
              {
                "@type": "OpeningHoursSpecification",
                dayOfWeek: [
                  "Monday",
                  "Tuesday",
                  "Wednesday",
                  "Thursday",
                  "Friday",
                ],
                opens: "09:00",
                closes: "18:00",
              },
            ],
            sameAs: [
              "https://www.facebook.com/habeprod",
              "https://www.instagram.com/habeprod",
              "https://www.linkedin.com/company/habeprod",
              "https://discord.gg/gna3b2YNUq",
            ],
          },
        ],
      })}
    />
  </head>

  <body>
    <slot />

    <!-- ✅ SÉCURITÉ LIENS EXTERNES -->
    <script>
      document.addEventListener("DOMContentLoaded", function () {
        document.querySelectorAll('a[target="_blank"]').forEach((link) => {
          link.setAttribute("rel", "noopener noreferrer");
        });
      });
    </script>
  </body>
</html>

<style is:global>
  @import "../styles/global.css";
</style>
