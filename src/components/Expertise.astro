<section class="expertise" id="expertise">
  <div class="container">
    <div class="section-subtitle">Notre approche</div>
    <h2 class="section-title">
      Notre expertise en communication digitale au Mans
    </h2>

    <div class="expertise-grid">
      <div class="expertise-item">
        <div class="expertise-number">01</div>
        <h3>Stratégie</h3>
        <p>
          Poser les bonnes fondations : positionnement, messages & objectifs
          clairs.
        </p>
      </div>
      <div class="expertise-item">
        <div class="expertise-number">02</div>
        <h3>Innovation</h3>
        <p>
          Imaginer des expériences digitales créatives, efficaces et adaptées
          aux usages.
        </p>
      </div>
      <div class="expertise-item">
        <div class="expertise-number">03</div>
        <h3>Créativité</h3>
        <p>
          Créer des identités visuelles singulières, des univers forts et des
          contenus qui marquent.
        </p>
      </div>
    </div>

    <div class="expertise-marquee">
      <div class="marquee-content">
        <span>Stratégie de communication</span>
        <span>Identité visuelle & branding</span>
        <span>Création de site web</span>
        <span>SEO & visibilité locale</span>
        <span>Social media & contenus</span>
        <span>Campagnes digitales</span>
        <span>Stratégie de communication</span>
        <span>Identité visuelle & branding</span>
        <span>Création de site web</span>
        <span>SEO & visibilité locale</span>
      </div>
    </div>
  </div>
</section>

<style>
  .expertise {
    background: #ffffff;
    color: #0a0a0a;
    min-height: 600px;
  }

  .expertise .section-subtitle {
    color: #6b7280;
  }

  .expertise-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 3rem;
    margin-top: 3rem;
  }

  .expertise-item {
    position: relative;
    padding-left: 4rem;
  }

  .expertise-number {
    position: absolute;
    left: 0;
    top: 0;
    font-size: 2.4rem;
    color: #6b7280;
  }

  .expertise-item h3 {
    font-size: 1.4rem;
    margin-bottom: 0.75rem;
  }

  .expertise-item p {
    color: #303438;
  }

  .expertise-marquee {
    margin-top: 3.5rem;
    overflow: hidden;
    white-space: nowrap;
    border-top: 1px solid rgba(0, 0, 0, 0.06);
    border-bottom: 1px solid rgba(0, 0, 0, 0.06);
    background: #ffffff;
    padding: 1.8rem 0;
  }

  .marquee-content {
    display: inline-block;
    animation: marquee 32s linear infinite;
  }

  .marquee-content span {
    margin: 0 3rem;
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: #6b7280;
  }

  @keyframes marquee {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }
</style>
