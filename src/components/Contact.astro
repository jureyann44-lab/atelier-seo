<section id="contact">
  <div class="container">
    <div class="contact-grid">
      <div class="contact-info">
        <p class="section-subtitle" aria-hidden="true">Formulaire de contact</p>
        <a href="mailto:contact@atelier-seo.fr">
          <span>contact@atelier-seo.fr</span><span aria-hidden="true">→</span
          >
        </a>
        <a href="tel:+33627252568">
          <span>+33 6 27 25 25 68</span><span aria-hidden="true">→</span>
        </a>
      </div>

      <form class="contact-form" id="contact-form">
        <input
          type="text"
          name="from_name"
          placeholder="Nom"
          required
          aria-label="Votre nom"
        />
        <input
          type="email"
          name="from_email"
          placeholder="Email"
          required
          aria-label="Votre email"
        />
        <input
          type="tel"
          name="phone"
          placeholder="Téléphone"
          aria-label="Votre téléphone"
        />
        <textarea
          name="message"
          placeholder="Message"
          required
          aria-label="Votre message"></textarea>
        <button type="submit" id="submit-btn">Envoyer</button>
        <p class="form-message" id="form-message"></p>
      </form>
    </div>
  </div>
</section>

<style>
  .contact-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(0, 1.1fr);
    gap: 3rem;
    margin-top: 2.5rem;
  }

  .contact-info a {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.4rem 0;
    text-decoration: none;
    color: inherit;
    border-bottom: 1px solid var(--color-border);
    font-size: 0.98rem;
    transition: opacity var(--transition-speed);
  }

  .contact-info a:hover {
    opacity: 0.7;
  }

  .contact-info a span:last-child {
    opacity: 0;
    transform: translateX(-15px);
    transition:
      opacity 0.6s ease,
      transform 0.6s ease;
  }

  .contact-info a:hover span:last-child {
    opacity: 1;
    transform: translateX(0);
  }

  :root {
    --color-border:#e5e5e5;
  }

  .contact-form input,
  .contact-form textarea {
    width: 100%;
    padding: 1rem;
    border-radius: 10px;
    border: 1px solid var(--color-border);
    font-family: inherit;
    font-size: 0.98rem;
    margin-bottom: 1rem;
    transition: border-color var(--transition-speed);
  }

  .contact-form input:focus,
  .contact-form textarea:focus {
    outline: none;
    border-color: var(--color-accent);
  }

  .contact-form textarea {
    min-height: 160px;
    resize: vertical;
  }

  .contact-form button {
    padding: 0.9rem 2.4rem;
    border-radius: 6px;
    border: none;
    background: var(--color-dark);
    color: #ffffff;
    font-weight: 600;
    cursor: pointer;
    transition:
      transform 0.25s,
      box-shadow 0.25s;
  }

  .contact-form button:hover {
    transform: translateY(-1px);
    box-shadow: 0 14px 30px rgba(15, 23, 42, 0.35);
  }

  .contact-form button:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .form-message {
    margin-top: 1rem;
    font-size: 0.95rem;
    text-align: center;
  }

  .form-message.success {
    color: #10b981;
  }

  .form-message.error {
    color: #ef4444;
  }

  /* 🔥 MOBILE (tactile OU petit écran) */
  @media (max-width: 900px), (max-width: 1023px) and (pointer: coarse) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  const WORKER_URL =
    "https://proud-bush-8032atelier-seo-contact-form.jure-yann44.workers.dev";
  const form = document.getElementById("contact-form");
  const submitBtn = document.getElementById("submit-btn");
  const message = document.getElementById("form-message");
  if (form) {
    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.textContent = "Envoi en cours...";
      }
      if (message) {
        message.textContent = "";
        message.className = "form-message";
      }
      try {
        const formData = new FormData(form);
        const data = {
          from_name: formData.get("from_name"),
          from_email: formData.get("from_email"),
          phone: formData.get("phone"),
          message: formData.get("message"),
        };
        const response = await fetch(WORKER_URL, {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
          },
          body: JSON.stringify(data),
        });
        const result = await response.json();
        if (result.success) {
          if (message) {
            message.textContent = "✅ Message envoyé avec succès !";
            message.classList.add("success");
          }
          form.reset();
        } else {
          throw new Error(result.error || "Erreur inconnue");
        }
      } catch (error) {
        if (message) {
          message.textContent = "❌ Erreur lors de l'envoi. Réessayez.";
          message.classList.add("error");
        }
      } finally {
        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.textContent = "Envoyer";
        }
      }
    });
  }
</script>