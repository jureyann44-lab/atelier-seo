---
import GoogleReviewsBadge from "./GoogleReviewsBadge.astro";
---

<footer>
  <div class="footer-content">
    <div class="footer-section-logo">
      <h3>Habeprod<span class="accent">°</span></h3>
    </div>
    <div class="footer-section footer-section-nav">
      <h3>Navigation</h3>
      <ul>
        <li>
          <a href="/#agence">
            <span class="link-text">L'agence</span><span class="arrow">→</span>
          </a>
        </li>
        <li>
          <a href="/#expertise">
            <span class="link-text">Expertise</span><span class="arrow">→</span>
          </a>
        </li>
        <li>
          <a href="/#projects">
            <span class="link-text">Réalisations</span><span class="arrow"
              >→</span
            >
          </a>
        </li>
        <li>
          <a href="/#contact">
            <span class="link-text">Contact</span><span class="arrow">→</span>
          </a>
        </li>
      </ul>
    </div>

    <div class="footer-section">
      <h3>Mentions obligatoires</h3>
      <ul>
        <li>
          <a href="/mentions-legales">
            <span class="link-text">Mentions légales</span><span class="arrow"
              >→</span
            >
          </a>
        </li>
        <li>
          <a href="/cgu">
            <span class="link-text">CGU</span><span class="arrow">→</span>
          </a>
        </li>
      </ul>
    </div>

    <!-- ✅ NOUVELLE SECTION - Avis Google -->
    <div class="footer-section footer-reviews">
      <h3>Nos avis</h3>
      <GoogleReviewsBadge
        rating={5.0}
        reviewCount={13}
        businessUrl="https://share.google/cqRIHTQP3u9IWAiJ5"
      />
    </div>
  </div>
</footer>

<!-- ✅ SECTION BLANCHE 80px SANS PADDING -->
<section class="footer-bottom-section">
  <div class="footer-bottom">
    Copyright © 2025 Habeprod – Agence de communication digitale
  </div>
</section>

<style>
  :root {
    --transition-speed: 0.3s ease;
  }

  footer {
    background: #020308;
    color: #ffffff;
    min-height: 450px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    padding: 2rem var(--gutter);
  }

  .footer-content {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2.5rem;
    align-items: stretch;
    max-width: var(--layout-width);
    width: 100%;
  }

  .footer-section-logo {
    display: flex;
    align-items: flex-start;
    padding-right: 1.5rem;
    border-right: 1px solid rgba(107, 114, 124, 0.8);
  }

  .accent {
    color: #ea6432;
    font-size: 1.1rem;
  }

  .footer-section h3 {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    margin-bottom: 0.8rem;
    opacity: 0.85;
  }

  .footer-section ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer-section a {
    text-decoration: none;
    color: #ffffff;
    display: block;
    position: relative;
    width: 100%;
    padding: 0.25rem 2.5rem 0.25rem 0;
    font-size: 0.95rem;
    transition: opacity var(--transition-speed);
    opacity: 0.85;
  }

  .footer-section a:hover {
    opacity: 1;
  }

  .footer-section a .link-text {
    display: inline-block;
  }

  .footer-section a .arrow {
    opacity: 0;
    position: absolute;
    right: 0;
    top: 50%;
    transform: translateX(-15px) translateY(-50%);
    transition:
      opacity 0.6s ease,
      transform 0.6s ease;
    display: inline-block;
    font-size: 1rem;
    font-weight: 100;
    line-height: 1;
  }

  .footer-section a:hover .arrow {
    opacity: 1;
    transform: translateX(0) translateY(-50%);
  }

  .footer-section-nav {
    border-right: 1px solid rgba(107, 114, 124, 0.8);
    padding-right: 1.5rem;
    height: 100%;
    align-self: stretch;
  }

  /* ✅ Section avis Google */
  .footer-reviews {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
  }

  /* ✅ SECTION BLANCHE 80px SANS AUCUN PADDING */
  .footer-bottom-section {
    background: #ffffff;
    height: 80px;
    width: 100vw;
    position: relative;
    left: 50%;
    right: 50%;
    margin-left: -50vw;
    margin-right: -50vw;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 0 !important;
    padding: 0 !important;
  }

  .footer-bottom {
    text-align: center;
    font-size: 0.9rem;
    color: #020308;
    opacity: 0.9;
    width: 100%;
    max-width: var(--layout-width);
  }

  /* 📱 TABLETTE - 2 colonnes */
  @media (max-width: 1024px) and (min-width: 768px) {
    .footer-content {
      grid-template-columns: repeat(2, 1fr);
      gap: 2rem;
    }

    .footer-section-logo,
    .footer-section-nav {
      border-right: none;
      padding-right: 0;
    }
  }

  /* 📱 MOBILE - 1 colonne */
  @media (max-width: 767px) {
    footer {
      min-height: auto;
      padding: 3rem var(--gutter-mobile);
    }

    .footer-content {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .footer-section-logo,
    .footer-section-nav {
      border-right: none;
      padding-right: 0;
    }
  }

  /* 📱 TABLETTE PORTRAIT - Réduit l'espace entre colonnes */
  @media (min-width: 768px) and (max-width: 1024px) and (orientation: portrait) {
    .footer-content {
      gap: 1rem !important;
    }

    .footer-section-logo {
      padding-right: 1rem !important;
    }

    .footer-section-nav {
      padding-right: 1rem !important;
    }
  }
</style>
