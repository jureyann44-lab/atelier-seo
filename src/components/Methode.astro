<script>
  (function () {
    const steps = document.getElementById('methode-steps');
    const fill = document.getElementById('methode-progress-fill');
    const nums = [
      document.getElementById('step-num-1'),
      document.getElementById('step-num-2'),
      document.getElementById('step-num-3'),
      document.getElementById('step-num-4'),
    ];

    if (!steps || !fill) return;

    function update() {
      const stepsRect = steps.getBoundingClientRect();
      const windowH = window.innerHeight;

      // Progression globale de la ligne (0 → 1)
      const total = stepsRect.height + windowH;
      const passed = windowH - stepsRect.top;
      const progress = Math.min(1, Math.max(0, passed / total));

      fill.style.height = (progress * 100) + '%';

      // Hauteur actuelle de la ligne en pixels depuis le haut du bloc steps
      const fillPx = progress * stepsRect.height;

      // Activer chaque numéro quand la ligne le dépasse
      nums.forEach(function (num) {
        if (!num) return;
        const numRect = num.getBoundingClientRect();
        // Position du centre du cercle par rapport au haut du bloc steps
        const numTop = numRect.top - stepsRect.top + numRect.height / 2;

        if (fillPx >= numTop) {
          num.classList.add('active');
        } else {
          num.classList.remove('active');
        }
      });
    }

    window.addEventListener('scroll', update, { passive: true });
    update();
  })();
</script>