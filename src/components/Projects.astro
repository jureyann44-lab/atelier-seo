---
const projects = [
  {
    tag: "SITE WEB – WORDPRESS",
    title: "Design Intérieur – Laure Mora",
    desc: "Depuis près de 20 ans, Laure Mora accompagne ses clients dans la création d'intérieurs uniques, où design et personnalité s'harmonisent avec élégance. À l'écoute de vos envies, elle privilégie une approche sur mesure, mêlant tendances actuelles, matériaux authentiques et sensibilité personnelle. Chaque projet devient une aventure créative pour transformer votre intérieur en un lieu de vie chaleureux, inspirant et à votre image.",
    image: "/projet-laure-mora-habeprod.webp",
    link: "https://lauremora.fr/",
  },
  {
    tag: "SITE WEB – WORDPRESS",
    title: "Pierre.SPS Coordination Sécurité Protection de la Santé",
    desc: "Spécialisée dans la coordination en matière de sécurité et de protection de la santé, notre entreprise intervient sur tous types de chantiers, du plus modeste au plus ambitieux, en Sarthe et dans les départements voisins. Portée par des valeurs humaines fortes, notre équipe mise sur l'écoute et la collaboration pour garantir des environnements de travail sûrs et conformes à la réglementation. Engagés dans une démarche RSE, nous œuvrons chaque jour pour une sécurité durable et responsable sur les sites de construction. Construisons ensemble un avenir plus sûr.",
    image: "/projet-spspierre-habeprod.webp",
    link: "https://www.pierresps-lemans.fr/",
  },
  {
    tag: "CATALOGUE – PRINT",
    title: "Apothical – Groupement pharmaceutique",
    desc: "Apothical s'engage à vous proposer des produits de parapharmacie de grandes marques au meilleur prix, des conseils d'experts santé et des services personnalisés et innovants.",
    image: "/projet-apotihical-habeprod.webp",
    link: "https://www.apothical.fr/",
  },
];
---

<section id="projects" class="projects-section">
  <div class="projects-inner">
    <div class="sticky-image-wrapper">
      <img
        class="sticky-image sticky-image--back"
        src={projects[0].image}
        alt={projects[0].title}
        loading="lazy"
      />
      <img
        class="sticky-image sticky-image--front"
        src={projects[0].image}
        alt={projects[0].title}
        loading="lazy"
      />
    </div>

    <div class="projects-list">
      {
        projects.map((project, index) => (
          <article
            class={`project-item ${index === 0 ? "is-active" : ""}`}
            data-image={project.image}
            data-index={index}
          >
            <div class="project-mobile-image">
              <img src={project.image} alt={project.title} loading="lazy" />
            </div>
            <div class="project-content">
              <p class="project-tag">{project.tag}</p>
              <h2 class="project-title">{project.title}</h2>
              <p class="project-desc">{project.desc}</p>
              
                class="project-link"
                href={project.link}
                target="_blank"
                rel="noopener noreferrer"
              >
                Découvrir le site →
              </a>
            </div>
          </article>
        ))
      }
    </div>
  </div>

  <header class="projects-header">
    <span class="projects-label">SERVICES</span>
    <div class="projects-progress">
      <div class="projects-progress-fill"></div>
    </div>
    <button
      class="projects-skip"
      type="button"
      aria-label="Passer à la section contact"
    >
      <span>SKIP</span><span aria-hidden="true">↓</span>
    </button>
  </header>
</section>

<style>
  .projects-section {
    background: #000;
    color: #fff;
    position: relative;
  }

  .projects-header {
    display: flex;
    align-items: center;
    gap: 2rem;
    padding-top: 10%;
  }

  .projects-label {
    font-size: 0.85rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .projects-progress {
    flex: 1;
    height: 2px;
    background: rgba(255, 255, 255, 0.18);
    position: relative;
    overflow: hidden;
  }

  .projects-progress-fill {
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 0;
    background: #ffffff;
    transition: width 0.6s ease-out;
  }

  .projects-skip {
    background: none;
    border: none;
    color: #ffffff;
    font-size: 0.85rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    cursor: pointer;
    transition: opacity var(--transition-speed);
  }

  .projects-skip:hover {
    opacity: 0.7;
  }

  .projects-inner {
    margin-top: 3rem;
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(0, 1.2fr);
    gap: 4rem;
    align-items: flex-start;
  }

  .sticky-image-wrapper {
    position: sticky;
    top: 15vh;
    width: 80%;
    max-width: 712px;
    aspect-ratio: 1 / 1;
    background: #1f2933;
    overflow: hidden;
    border-radius: 8px;
    will-change: transform;
    transform: rotate(180deg);
    isolation: isolate;
    align-self: flex-start;
    height: fit-content;
  }

  .sticky-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    will-change: transform, opacity;
    transform: scale(1.42) rotate(-180deg);
    transition: opacity var(--project-fade-duration) ease-in-out;
  }

  .sticky-image--back {
    opacity: 1;
  }

  .sticky-image--front {
    opacity: 0;
  }

  .sticky-image--front.is-visible {
    opacity: 1;
  }

  .projects-list {
    display: flex;
    flex-direction: column;
    gap: 5rem;
    padding-bottom: 50vh;
  }

  .project-item {
    opacity: 0.4;
    transform: translateY(20px);
    transition:
      opacity 0.35s ease-out,
      transform 0.35s ease-out;
    min-height: 80vh;
  }

  .project-item.is-active {
    opacity: 1;
    transform: translateY(0);
  }

  /* Image mobile cachée en desktop */
  .project-mobile-image {
    display: none;
  }

  .project-tag {
    font-size: 0.75rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.7);
    margin-bottom: 0.75rem;
  }

  .project-desc {
    line-height: 1.8;
    color: rgba(255, 255, 255, 0.8);
  }

  .project-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-top: 1.25rem;
    padding: 0.75rem 1.4rem;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.35);
    font-size: 0.95rem;
    text-decoration: none;
    color: #ffffff;
    transition:
      transform 0.25s ease,
      opacity var(--transition-speed);
    --outline-hover-color: rgba(255, 255, 255, 1);
  }

  .project-link:hover {
    opacity: 0.95;
    transform: translateY(-1px);
  }

  @media (max-width: 900px) {
    .projects-inner {
      grid-template-columns: 1fr;
      gap: 0;
    }

    /* Cacher l'image sticky en mobile */
    .sticky-image-wrapper {
      display: none;
    }

    .projects-list {
      gap: 4rem;
    }

    .project-item {
      min-height: auto;
      opacity: 1;
      transform: translateY(0);
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    /* Afficher l'image mobile */
    .project-mobile-image {
      display: block;
      width: 100%;
      aspect-ratio: 1 / 1;
      border-radius: 8px;
      overflow: hidden;
      background: #1f2933;
    }

    .project-mobile-image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }
  }
</style>

<script>
  const section = document.querySelector(".projects-section");
  const items = Array.from(document.querySelectorAll(".project-item"));
  const stickyWrapper = document.querySelector(".sticky-image-wrapper");
  const stickyBack = document.querySelector(".sticky-image--back");
  const stickyFront = document.querySelector(".sticky-image--front");
  const progressFill = document.querySelector(".projects-progress-fill");
  const skipButton = document.querySelector(".projects-skip");

  let ticking = false;
  let swapTimeout = null;

  function requestTick() {
    if (ticking) return;
    ticking = true;
    requestAnimationFrame(() => {
      handleRotation();
      ticking = false;
    });
  }

  function handleRotation() {
    if (!section || !stickyWrapper || !stickyBack || !stickyFront) return;

    const rect = section.getBoundingClientRect();
    const viewportHeight = window.innerHeight;
    const ENTER_THRESHOLD = 0.2;
    const EXIT_THRESHOLD = 0.2;
    const sectionHeight = rect.height;
    const start = viewportHeight;
    const end = -sectionHeight;
    const totalDistance = start - end;

    let rawProgress = (start - rect.top) / totalDistance;
    rawProgress = Math.max(0, Math.min(1, rawProgress));

    if (progressFill) progressFill.style.width = `${rawProgress * 100}%`;

    if (rawProgress < ENTER_THRESHOLD || rawProgress > 1 - EXIT_THRESHOLD) {
      stickyWrapper.style.transform = "rotate(180deg)";
      stickyBack.style.transform = "scale(1.42) rotate(-180deg)";
      stickyFront.style.transform = "scale(1.42) rotate(-180deg)";
      return;
    }

    const activeRange = 1 - ENTER_THRESHOLD - EXIT_THRESHOLD;
    let progress = (rawProgress - ENTER_THRESHOLD) / activeRange;
    progress = Math.max(0, Math.min(1, progress));
    const rotation = 180 + progress * 360;

    stickyWrapper.style.transform = `rotate(${rotation}deg)`;
    stickyBack.style.transform = `scale(1.42) rotate(${-rotation}deg)`;
    stickyFront.style.transform = `scale(1.42) rotate(${-rotation}deg)`;
  }

  function crossfadeTo(newSrc) {
    if (!newSrc || !stickyBack || !stickyFront) return;
    if (stickyBack.src.includes(newSrc)) return;

    if (swapTimeout) clearTimeout(swapTimeout);

    const preloader = new Image();
    preloader.onload = () => {
      stickyFront.classList.remove("is-visible");
      stickyFront.src = newSrc;

      requestAnimationFrame(() => stickyFront.classList.add("is-visible"));

      const durStr = getComputedStyle(document.documentElement)
        .getPropertyValue("--project-fade-duration")
        .trim()
        .replace("s", "");
      const dur = parseFloat(durStr);
      const ms = Number.isFinite(dur) ? dur * 1000 : 1200;

      swapTimeout = setTimeout(() => {
        stickyBack.src = newSrc;
        stickyFront.classList.remove("is-visible");
      }, ms);
    };

    preloader.src = newSrc;
  }

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;
        const el = entry.target;

        items.forEach((p) => p.classList.remove("is-active"));
        el.classList.add("is-active");

        const newSrc = el.dataset.image;
        if (newSrc) crossfadeTo(newSrc);
      });
    },
    { rootMargin: "-40% 0px -40% 0px", threshold: 0.1 }
  );

  items.forEach((item) => observer.observe(item));

  window.addEventListener("scroll", requestTick, { passive: true });
  window.addEventListener("resize", requestTick, { passive: true });

  skipButton?.addEventListener("click", () => {
    document
      .querySelector("#contact")
      ?.scrollIntoView({ behavior: "smooth", block: "start" });
  });

  handleRotation();
</script>