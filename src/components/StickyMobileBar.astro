      <polyline points="22,6 12,13 2,6"/>
    </svg>
    <span>Email</span>
  </a>
</div>

<style>
  .sticky-bar {
    display: none;
  }

  @media (max-width: 480px) and (orientation: portrait),
         (max-width: 767px) and (pointer: coarse) and (orientation: portrait) {
    .sticky-bar {
      display: flex;
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      z-index: 999;
      background: #0a0a0a;
      border-top: 1px solid rgba(255, 255, 255, 0.12);
      padding: 0.6rem 1rem calc(0.6rem + env(safe-area-inset-bottom));
      gap: 0.5rem;
      justify-content: space-around;
      align-items: center;
      bottom: -120px;
      transition: bottom 0.3s ease;
      will-change: transform;
      transform: translateZ(0);
    }

    .sticky-bar.visible {
      bottom: 0;
    }

    .sticky-btn {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.3rem;
      text-decoration: none;
      color: #ffffff;
      font-size: 0.65rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      font-family: 'Montserrat', sans-serif;
      padding: 0.4rem 0.8rem;
      border-radius: 8px;
      transition: color 0.2s ease, background 0.2s ease;
      flex: 1;
    }

    .sticky-btn:active {
      background: rgba(255, 255, 255, 0.05);
    }

    .sticky-btn--tel:hover,
    .sticky-btn--tel:active {
      color: #34d399;
    }

    .sticky-btn--linkedin:hover,
    .sticky-btn--linkedin:active {
      color: #0a66c2;
    }

    .sticky-btn--instagram:hover,
    .sticky-btn--instagram:active {
      color: #e1306c;
    }

    .sticky-btn--mail:hover,
    .sticky-btn--mail:active {
      color: #ea6432;
    }
  }
</style>

<script>
  const bar = document.getElementById('sticky-bar');
  let lastScrollY = window.scrollY;
  let ticking = false;
  let ready = false;

  window.addEventListener("load", () => {
    setTimeout(() => {
      ready = true;
      updateBar();
    }, 350); // temps pour stabiliser viewport Chrome privé
  });

  function updateBar() {
    if (!ready) return;
    const scrollY = window.scrollY;
    const windowHeight = window.visualViewport
      ? window.visualViewport.height
      : window.innerHeight;
    const docHeight = document.documentElement.scrollHeight;

    if (scrollY > lastScrollY && scrollY > 100) {
      bar?.classList.add('visible');
    } else if (scrollY < lastScrollY) {
      bar?.classList.remove('visible');
    }

    if (scrollY + windowHeight >= docHeight - 50) {
      bar?.classList.add('visible');
    }

    lastScrollY = scrollY;
    ticking = false;
  }

  window.addEventListener('scroll', () => {
    if (!ticking) {
      requestAnimationFrame(updateBar);
      ticking = true;
    }
  }, { passive: true });
</script>