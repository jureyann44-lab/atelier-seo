    bottom: -70px;
    width: 50%;
    height: 70px;
    background: #ffffff;
    z-index: 3;
  }

  /* 📱 MOBILE LANDSCAPE - Même format que 900px mais ultra compact */
  @media (max-width: 767px) and (orientation: landscape) {
    .about {
      padding: 2rem 0;
    }

    .about-inner {
      grid-template-columns: 1fr;
      row-gap: 1rem;
      padding-left: var(--gutter-mobile);
