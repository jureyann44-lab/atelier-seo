<section class="about" id="agence">
  <div class="about-inner">
    <div class="about-image">
      <img
        src="/bureau-agence-habeprod.webp"
        alt="Bureau de l'agence Habeprod au Mans"
        loading="lazy"
      />
    </div>
    <div class="about-text">
      <div class="section-subtitle">À propos</div>
      <h2 class="section-title">
        Communication, design & visibilité pour les entreprises du Mans
      </h2>
      <p class="about-body">
        Chez <span>Habeprod</span>, nous accompagnons les <span
          >entreprises du Mans et de la Sarthe</span
        > dans leurs projets de <span>communication digitale</span>. Notre
        équipe conçoit des <span>sites web performants</span>, optimisés pour le <span
          >référencement local</span
        >, et déploie des <span>stratégies de communication sur mesure</span> : <span
          >identité visuelle</span
        >, <span>branding</span>, <span>réseaux sociaux</span> et <span
          >contenus</span
        >. Agence de proximité, nous mettons notre <span>expertise</span> au service
        des <span>TPE, PME et artisans</span>, avec un <span
          >suivi personnalisé</span
        > adapté à votre <span>secteur d'activité</span>.
      </p>
      <div class="btn-container">
        <a href="#expertise" class="btn-expertise">
          <span>Notre expertise</span>
        </a>
      </div>
    </div>
  </div>
  <div class="about-bottom-strip"></div>
</section>

<style>
  .about {
    background: #ffffff;
    position: relative;
  }

  .about-inner {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(0, 1fr);
    column-gap: 4rem;
    align-items: center;
  }

  .about-image {
    width: 100%;
    max-width: 500.39px;
    height: 596px;
    overflow: hidden;
    opacity: 0;
    transform: translateY(60px);
    transition:
      opacity 0.9s ease-out,
      transform 0.9s ease-out;
    will-change: opacity, transform;
  }

  .about-image.in-view {
    opacity: 1;
    transform: translateY(0);
  }

  .about-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .about-text {
    color: #111827;
  }

  .about-text .section-subtitle {
    color: #9ca3af;
  }

  .about-body {
    line-height: 1.8;
    color: #4b5563;
    margin-bottom: 1.5rem;
  }

  /* ✅ CONTENEUR DU BOUTON - Aligné à gauche */
  .btn-container {
    display: flex;
    justify-content: flex-start;
    margin-top: 1rem;
  }

  /* ✅ BOUTON EXPERTISE */
  .btn-expertise {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.95rem 2.6rem;
    border-radius: 999px;
    border: 1px solid rgba(0, 0, 0, 0.35);
    text-decoration: none;
    font-size: 0.85rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #000;
    background: transparent;
    transition: all var(--transition-speed);
  }

  .btn-expertise:hover {
    box-shadow: 0 6px 25px rgba(0, 0, 0, 0.25);
    transform: translateY(-1px);
  }

  .about-bottom-strip {
    position: absolute;
    right: 0;
    bottom: -70px;
    width: 50%;
    height: 70px;
    background: #ffffff;
    z-index: 3;
  }

  /* 📱 MOBILE LANDSCAPE */
  @media (min-width: 667px) and (max-width: 960px) and (orientation: landscape) and (max-height: 450px) {
    .about {
      padding: 2rem 0;
    }

    .about-inner {
      grid-template-columns: 1fr;
      row-gap: 1rem;
      max-width: 90% !important;
      margin: 0 auto !important;
      padding-left: 2rem !important;
      padding-right: 2rem !important;
    }

    .about-image {
      order: -1;
      width: 100%;
      max-width: 100%;
      height: auto;
      aspect-ratio: 1 / 1;
    }

    .about-image img {
      object-fit: cover;
      width: 100%;
      height: 100%;
    }

    .section-subtitle {
      font-size: 0.65rem;
      margin-bottom: 0.3rem;
    }

    .section-title {
      font-size: 20px !important;
      line-height: 1.15 !important;
      margin-bottom: 0.6rem !important;
    }

    .about-body {
      font-size: 0.95rem;
      line-height: 1.5;
      margin-bottom: 0.4rem;
    }

    .btn-expertise {
      font-size: 0.75rem;
      padding: 0.8rem 2rem;
      transition: none;
    }

    .btn-expertise:hover {
      transform: none;
    }

    .about-bottom-strip {
      display: none;
    }
  }

  /* 📱 TABLETTE + MOBILE PORTRAIT */
  @media (max-width: 900px) and (orientation: portrait) {
    .about-inner {
      grid-template-columns: 1fr;
      row-gap: 2.5rem;
    }

    .about-image {
      order: -1;
      width: 100%;
      max-width: 100%;
      height: auto;
      aspect-ratio: 4/5;
    }

    .btn-expertise {
      transition: none;
    }

    .btn-expertise:hover {
      transform: none;
    }

    .about-bottom-strip {
      display: none !important;
    }
  }
</style>

<script>
  const aboutImage = document.querySelector(".about-image");

  if (aboutImage) {
    const observer = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          aboutImage.classList.add("in-view");
          observer.unobserve(aboutImage);
        }
      },
      { threshold: 0.25 },
    );
    observer.observe(aboutImage);
  }
</script>
