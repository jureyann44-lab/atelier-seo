<style>
  .about {
    background: #ffffff;
    position: relative;
  }

  .about-inner {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(0, 1fr);
    column-gap: 4rem;
    align-items: center;
  }

  .about-image {
    width: 100%;
    max-width: 500.39px;
    height: 596px;
    overflow: hidden;
    opacity: 0;
    transform: translateY(60px);
    transition:
      opacity 0.9s ease-out,
      transform 0.9s ease-out;
    will-change: opacity, transform;
  }

  .about-image.in-view {
